---
// Root of the platform ("/"): the DigiSigns brand landing / template showcase.
// Source: Stitch project 13817036897071013700, screen
// 14d0f3d8448e4542a8cd58c1298420d4 ("DigiSigns - Portfolio Landing Page by
// John Lamigo"). This is platform-level chrome, not one of the
// /templates/<slug>/ business templates, so it gets its own theme
// (src/styles/themes/digisigns.css) rather than a template folder.
import BaseLayout from "@/layouts/BaseLayout.astro";
import "@/styles/themes/digisigns.css";
import { templates } from "@/lib/templates";

const featured = templates.find((t) => t.featured);
const upcoming = templates.filter((t) => !t.featured);
---

<BaseLayout
  title="DigiSigns | Bespoke Digital Systems by John Lamigo"
  description="High-performing WordPress solutions and conversion-focused funnels, engineered by John Lamigo. Browse the DigiSigns template collection."
  htmlClass="scroll-smooth dark"
  bodyClass="theme-digisigns bg-background text-on-surface font-body-md selection:bg-primary selection:text-on-primary overflow-x-hidden"
>
  <Fragment slot="head">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <style>
      .material-symbols-outlined {
        font-variation-settings: "FILL" 0, "wght" 300, "GRAD" 0, "opsz" 24;
      }
      .reveal-on-scroll {
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
      }
      .reveal-on-scroll.active {
        opacity: 1;
        transform: translateY(0);
      }
    </style>
  </Fragment>

  <!-- Top Navigation Bar -->
  <nav class="fixed top-0 left-0 w-full z-50 bg-surface border-b border-border-subtle">
    <div class="flex justify-between items-center w-full px-gutter max-w-container-max mx-auto h-20">
      <div class="font-headline-md text-headline-md font-bold text-text-primary">DigiSigns</div>
      <div class="hidden md:flex gap-8 items-center">
        <a class="font-body-md text-body-md text-primary font-bold border-b-2 border-primary pb-1 active:scale-95 transition-transform" href="#collection">Template Collection</a>
        <a class="font-body-md text-body-md text-text-muted hover:text-primary transition-colors duration-200 active:scale-95 transition-transform" href="#">About the Creator</a>
        <a class="font-body-md text-body-md text-text-muted hover:text-primary transition-colors duration-200 active:scale-95 transition-transform" href="#">Hire John</a>
      </div>
      <button class="bg-primary-container text-on-primary-container font-label-sm text-label-sm uppercase px-8 py-3 tracking-widest hover:bg-primary transition-all duration-300 active:scale-95 transition-transform">
        Hire John
      </button>
    </div>
  </nav>

  <!-- Hero Section -->
  <header class="relative min-h-screen flex items-center justify-center pt-24 overflow-hidden bg-surface-deep">
    <div class="relative z-10 max-w-container-max mx-auto px-margin-desktop text-center">
      <span class="font-label-sm text-label-sm uppercase tracking-[0.4em] text-secondary-fixed-dim mb-6 block reveal-on-scroll">Engineered by John Lamigo</span>
      <h1 class="font-display-hero text-display-hero-mobile md:text-display-hero leading-tight text-text-primary mb-8 max-w-5xl mx-auto reveal-on-scroll" style="transition-delay: 0.1s">
        Bespoke Digital <span class="text-primary">Systems</span> by John Lamigo.
      </h1>
      <p class="font-body-lg text-body-lg text-text-muted max-w-3xl mx-auto mb-12 reveal-on-scroll" style="transition-delay: 0.2s">
        High-performing WordPress solutions and conversion-focused funnels. Designed and engineered by a WordPress Engineer &amp; Digital Strategist with 7+ years of experience building scalable digital assets.
      </p>
      <div class="flex flex-col md:flex-row gap-6 justify-center reveal-on-scroll" style="transition-delay: 0.3s">
        <a class="bg-primary-container text-on-primary-container px-12 py-5 font-label-sm text-label-sm uppercase tracking-widest hover:bg-primary transition-all duration-300 shadow-xl" href="#collection">
          Explore the Collection
        </a>
        <a class="border border-outline px-12 py-5 font-label-sm text-label-sm uppercase tracking-widest hover:bg-surface-bright transition-all duration-300" href="#">
          View Digital Strategy
        </a>
      </div>
    </div>
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-50">
      <span class="material-symbols-outlined text-primary">keyboard_double_arrow_down</span>
    </div>
  </header>

  <!-- Pillar Section -->
  <section class="py-stack-lg bg-surface-container-low border-y border-border-subtle">
    <div class="max-w-container-max mx-auto px-margin-desktop grid grid-cols-1 md:grid-cols-3 gap-gutter">
      <div class="text-center md:text-left reveal-on-scroll">
        <h3 class="font-label-sm text-label-sm uppercase tracking-widest text-secondary-fixed-dim mb-4">WordPress Engineering</h3>
        <p class="font-body-md text-text-muted">Handcrafted code and pixel-perfect execution by John Lamigo, ensuring sub-2s load times and SEO optimization.</p>
      </div>
      <div class="text-center md:text-left reveal-on-scroll" style="transition-delay: 0.1s">
        <h3 class="font-label-sm text-label-sm uppercase tracking-widest text-secondary-fixed-dim mb-4">Conversion Strategy</h3>
        <p class="font-body-md text-text-muted">Data-driven layouts designed for growth, leveraging 7+ years of experience in CRO and marketing automation.</p>
      </div>
      <div class="text-center md:text-left reveal-on-scroll" style="transition-delay: 0.2s">
        <h3 class="font-label-sm text-label-sm uppercase tracking-widest text-secondary-fixed-dim mb-4">Automated Systems</h3>
        <p class="font-body-md text-text-muted">Clean, scalable architectures integrated with CRM workflows and high-performance marketing funnels.</p>
      </div>
    </div>
  </section>

  <!-- Industry Filter Bar -->
  <section class="sticky top-20 z-40 bg-surface/90 backdrop-blur-md py-6 border-b border-border-subtle">
    <div class="max-w-container-max mx-auto px-margin-desktop flex flex-wrap gap-8 justify-center items-center">
      <span class="font-label-sm text-label-sm uppercase text-outline">Filter By Expertise:</span>
      <button class="font-label-sm text-label-sm uppercase tracking-widest text-primary border-b-2 border-primary">All Systems</button>
      <button class="font-label-sm text-label-sm uppercase tracking-widest text-text-muted hover:text-primary transition-colors">B2B Services</button>
      <button class="font-label-sm text-label-sm uppercase tracking-widest text-text-muted hover:text-primary transition-colors">Healthcare</button>
      <button class="font-label-sm text-label-sm uppercase tracking-widest text-text-muted hover:text-primary transition-colors">Real Estate</button>
      <button class="font-label-sm text-label-sm uppercase tracking-widest text-text-muted hover:text-primary transition-colors">E-Commerce</button>
      <button class="font-label-sm text-label-sm uppercase tracking-widest text-text-muted hover:text-primary transition-colors">SaaS Funnels</button>
    </div>
  </section>

  <!-- Main Showcase (featured template) -->
  {featured && (
    <section class="py-24 bg-surface" id="collection">
      <div class="max-w-container-max mx-auto px-margin-desktop">
        <div class="flex flex-col lg:flex-row gap-16 items-center">
          <div class="lg:w-1/2 reveal-on-scroll">
            <span class="font-label-sm text-label-sm uppercase text-secondary-fixed-dim tracking-widest mb-4 block">{featured.releaseNote}</span>
            <h2 class="font-headline-lg text-headline-lg text-text-primary mb-6">High-Performance {featured.industry}: <br /><span class="text-primary">{featured.name}</span></h2>
            <p class="font-body-lg text-body-lg text-text-muted mb-8">{featured.tagline}</p>
            <div class="grid grid-cols-2 gap-6 mb-10">
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-secondary-fixed-dim">verified</span>
                <span class="font-label-sm text-label-sm uppercase">John's Signature Kit</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-secondary-fixed-dim">speed</span>
                <span class="font-label-sm text-label-sm uppercase">Sub-2s Load Speed</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-secondary-fixed-dim">insights</span>
                <span class="font-label-sm text-label-sm uppercase">CRO Integrated</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-secondary-fixed-dim">settings_input_component</span>
                <span class="font-label-sm text-label-sm uppercase">Full Funnel Build</span>
              </div>
            </div>
            {featured.status === "live" ? (
              <a href={`/templates/${featured.slug}/`} class="bg-primary-container text-on-primary-container px-10 py-4 font-label-sm text-label-sm uppercase tracking-widest hover:bg-primary transition-all shadow-lg flex items-center gap-4 w-fit">
                Live System Preview <span class="material-symbols-outlined">arrow_forward</span>
              </a>
            ) : (
              <button class="bg-primary-container text-on-primary-container px-10 py-4 font-label-sm text-label-sm uppercase tracking-widest hover:bg-primary transition-all shadow-lg flex items-center gap-4">
                Live System Preview <span class="material-symbols-outlined">arrow_forward</span>
              </button>
            )}
          </div>
          <div class="lg:w-1/2 relative reveal-on-scroll" style="transition-delay: 0.2s">
            <div class="bg-surface-container-high p-4 shadow-2xl rounded-sm transform hover:-translate-y-2 transition-transform duration-500 overflow-hidden border border-border-subtle">
              <div class="aspect-[16/10] bg-surface-container overflow-hidden group">
                <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000 opacity-80" alt={`Preview of the ${featured.name} template`} src={featured.previewImage} />
              </div>
            </div>
            <div class="absolute -bottom-10 -left-10 bg-surface-bright border border-border-subtle text-text-primary px-8 py-8 shadow-xl hidden md:block">
              <div class="font-metric-display text-metric-display text-primary">01</div>
              <div class="font-label-sm text-label-sm uppercase tracking-widest">{featured.industry}</div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Stats Banner -->
  <section class="bg-surface-container-highest py-16 border-y border-border-subtle">
    <div class="max-w-container-max mx-auto px-margin-desktop grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
      <div>
        <div class="font-metric-display text-metric-display text-primary mb-2">200+</div>
        <div class="font-label-sm text-label-sm uppercase text-text-muted tracking-widest">Websites Built by John</div>
      </div>
      <div>
        <div class="font-metric-display text-metric-display text-primary mb-2">30%</div>
        <div class="font-label-sm text-label-sm uppercase text-text-muted tracking-widest">Avg Conversion Lift</div>
      </div>
      <div>
        <div class="font-metric-display text-metric-display text-primary mb-2">7+</div>
        <div class="font-label-sm text-label-sm uppercase text-text-muted tracking-widest">Years Strategy Experience</div>
      </div>
    </div>
  </section>

  <!-- Upcoming Previews Grid -->
  <section class="py-24 bg-surface-container-lowest">
    <div class="max-w-container-max mx-auto px-margin-desktop">
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
        <div>
          <span class="font-label-sm text-label-sm uppercase text-secondary-fixed-dim tracking-widest mb-4 block">The Pipeline by John Lamigo</span>
          <h2 class="font-headline-lg text-headline-lg text-text-primary">Coming Soon to DigiSigns</h2>
        </div>
        <div class="hidden md:block">
          <button class="border-b border-primary py-2 font-label-sm text-label-sm uppercase tracking-widest text-text-primary hover:text-primary hover:border-primary transition-all">Request Custom Build</button>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter">
        {upcoming.map((t, i) => (
          <div class="group reveal-on-scroll" style={i % 3 !== 0 ? `transition-delay: ${(i % 3) * 0.1}s` : undefined}>
            <div class="aspect-square bg-surface overflow-hidden mb-6 relative border border-border-subtle">
              <div class="absolute inset-0 bg-surface-deep/80 opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-10 flex items-center justify-center">
                <button class="bg-primary-container text-on-primary-container px-8 py-3 font-label-sm text-label-sm uppercase tracking-widest">Inspect Build</button>
              </div>
              <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-70" alt={`Preview of the ${t.name} template`} src={t.previewImage} />
              {t.releaseNote && (
                <div class="absolute top-4 right-4 bg-surface-bright/90 backdrop-blur px-3 py-1 font-label-sm text-[10px] uppercase tracking-widest z-20 text-text-primary border border-border-subtle">{t.releaseNote}</div>
              )}
            </div>
            <h3 class="font-headline-md text-headline-md text-text-primary mb-2">{t.name}</h3>
            <p class="font-label-sm text-label-sm uppercase text-text-muted tracking-widest">Engineered by John Lamigo</p>
          </div>
        ))}
        <!-- Custom Request -->
        <div class="border-2 border-dashed border-border-subtle aspect-square flex flex-col items-center justify-center p-12 text-center group hover:border-primary transition-colors cursor-pointer reveal-on-scroll">
          <span class="material-symbols-outlined text-4xl text-outline group-hover:text-primary mb-4">add_circle</span>
          <h3 class="font-headline-md text-headline-md text-text-primary/40 group-hover:text-text-primary mb-2">Bespoke Strategy</h3>
          <p class="font-body-md text-text-muted/60">Hire John for custom WordPress development and digital strategy tailored to your growth goals.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA Section -->
  <section class="py-24 bg-surface border-t border-border-subtle overflow-hidden relative">
    <div class="max-w-container-max mx-auto px-margin-desktop text-center relative z-10">
      <h2 class="font-display-hero text-display-hero-mobile md:text-headline-lg text-text-primary mb-8 max-w-4xl mx-auto">Elevate Your Practice with <span class="text-primary">Bespoke Systems</span>.</h2>
      <p class="font-body-lg text-body-lg text-text-muted mb-12 max-w-2xl mx-auto">
        Select a DigiSigns blueprint or consult with John Lamigo to engineer a custom digital experience for your brand.
      </p>
      <div class="flex flex-col md:flex-row gap-6 justify-center">
        <button class="bg-primary-container text-on-primary-container px-16 py-6 font-label-sm text-label-sm uppercase tracking-widest hover:bg-primary transition-all shadow-2xl">
          Start Your Project
        </button>
        <button class="flex items-center gap-4 px-16 py-6 font-label-sm text-label-sm uppercase tracking-widest border border-outline hover:bg-surface-bright transition-all">
          Hire John <span class="material-symbols-outlined">person_add</span>
        </button>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="w-full bg-surface-deep border-t border-border-subtle">
    <div class="flex flex-col md:flex-row justify-between items-center w-full px-gutter py-stack-md max-w-container-max mx-auto">
      <div class="mb-6 md:mb-0">
        <div class="font-headline-md text-headline-md font-bold text-text-primary">DigiSigns</div>
        <p class="font-label-sm text-label-sm text-text-muted mt-2">Bespoke Digital Systems by John Lamigo</p>
      </div>
      <div class="flex flex-col md:flex-row items-center gap-8">
        <div class="flex gap-6">
          <a class="font-label-sm text-label-sm text-text-muted hover:text-secondary-fixed-dim transition-colors duration-200 active:opacity-80" href="#">LinkedIn</a>
          <a class="font-label-sm text-label-sm text-text-muted hover:text-secondary-fixed-dim transition-colors duration-200 active:opacity-80" href="https://github.com/digisyn-co">GitHub</a>
          <a class="font-label-sm text-label-sm text-text-muted hover:text-secondary-fixed-dim transition-colors duration-200 active:opacity-80" href="#">Twitter</a>
          <a class="font-label-sm text-label-sm text-text-muted hover:text-secondary-fixed-dim transition-colors duration-200 active:opacity-80" href="#">Portfolio</a>
        </div>
        <p class="font-label-sm text-label-sm text-text-muted">© 2026 DigiSigns by John Lamigo. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script>
    // Intersection Observer for reveal animations
    const observerOptions = {
      threshold: 0.1,
      rootMargin: "0px 0px -50px 0px",
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("active");
        }
      });
    }, observerOptions);

    document.querySelectorAll(".reveal-on-scroll").forEach((el) => observer.observe(el));

    // Smooth scroll for in-page anchor links
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener("click", function (e) {
        const href = this.getAttribute("href");
        if (!href || href === "#") return;
        const target = document.querySelector(href);
        if (!target) return;
        e.preventDefault();
        target.scrollIntoView({ behavior: "smooth" });
      });
    });
  </script>
</BaseLayout>
