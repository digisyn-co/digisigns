---
import TemplateLayout from "@/templates/law-prestige/TemplateLayout.astro";
---

<TemplateLayout
  title="Contact | Prestige Law"
  description="Initiate a confidential case review with Prestige Law's principals."
  active="contact"
  canonicalPath="/templates/law-prestige/contact"
>
<main class="relative">
<!-- Hero Section -->
<section class="max-w-lp-container-max mx-auto px-margin-desktop pt-stack-lg pb-lp-stack-md">
<div class="max-w-3xl">
<span class="font-lp-label-sm text-lp-label-sm uppercase tracking-[0.3em] text-secondary mb-4 block">Exclusive Representation</span>
<h1 class="font-display-lg text-display-lg md:text-[64px] leading-[1.1] mb-8">Secure Counsel.</h1>
<p class="font-body-lg text-body-lg text-on-surface-variant leading-relaxed">
                    Reserved for high-net-worth individuals and institutional leaders. Our litigation firm operates with absolute discretion and precision in the world's most complex legal theaters.
                </p>
</div>
</section>
<!-- Main Grid -->
<section class="max-w-lp-container-max mx-auto px-margin-desktop grid grid-cols-1 lg:grid-cols-12 gap-gutter items-start pb-stack-lg">
<!-- Lead Form Column -->
<div class="lg:col-span-7 bg-surface-container-lowest p-10 deep-shadow rounded-lg border border-outline-variant/10">
<h2 class="font-lp-headline-md text-lp-headline-md mb-10">Initiate Discretionary Inquiry</h2>
<form class="space-y-12" id="lawContactForm" data-success-target="#lawConfirmationState">
<div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
<div class="flex flex-col gap-2">
<label class="font-lp-label-sm text-lp-label-sm uppercase text-outline">Full Legal Name</label>
<input class="border-b border-outline bg-transparent py-2 focus:border-secondary outline-none transition-colors font-body-md" placeholder="e.g. Alexander Vance" type="text"/>
</div>
<div class="flex flex-col gap-2">
<label class="font-lp-label-sm text-lp-label-sm uppercase text-outline">Email Address (Secure)</label>
<input class="border-b border-outline bg-transparent py-2 focus:border-secondary outline-none transition-colors font-body-md" placeholder="av@institutional.com" type="email"/>
</div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
<div class="flex flex-col gap-2">
<label class="font-lp-label-sm text-lp-label-sm uppercase text-outline">Institutional Affiliation</label>
<input class="border-b border-outline bg-transparent py-2 focus:border-secondary outline-none transition-colors font-body-md" placeholder="Organization / Family Office" type="text"/>
</div>
<div class="flex flex-col gap-2">
<label class="font-lp-label-sm text-lp-label-sm uppercase text-outline">Case Type</label>
<select class="border-b border-outline bg-transparent py-2 focus:border-secondary outline-none transition-colors font-body-md appearance-none">
<option>Select Category</option>
<option>Cross-Border Dispute</option>
<option>Asset Protection</option>
<option>Regulatory Defense</option>
<option>Reputation Management</option>
</select>
</div>
</div>
<div class="flex flex-col gap-2">
<label class="font-lp-label-sm text-lp-label-sm uppercase text-outline">Nature of Inquiry</label>
<textarea class="border-b border-outline bg-transparent py-2 focus:border-secondary outline-none transition-colors font-body-md resize-none" placeholder="Provide a high-level summary of the matter..." rows="4"></textarea>
</div>
<div class="flex items-center gap-4">
<input class="w-4 h-4 text-secondary focus:ring-secondary border-outline rounded-sm" id="nda" type="checkbox"/>
<label class="font-label-md text-label-md text-on-surface-variant" for="nda">Request standard mutual NDA prior to detailed discussion</label>
</div>
<button class="w-full md:w-auto bg-primary text-on-primary px-12 py-5 font-label-md uppercase tracking-widest hover:bg-secondary transition-all duration-300" type="submit">
                        Submit Inquiry
                    </button>
</form>
<div class="hidden text-center py-16" id="lawConfirmationState">
<span class="material-symbols-outlined text-6xl text-secondary mb-6" style="font-variation-settings: 'FILL' 1;">verified</span>
<h3 class="font-lp-headline-md text-lp-headline-md mb-4">Inquiry Received</h3>
<p class="font-body-md text-on-surface-variant max-w-md mx-auto">Your matter has been logged with our intake team under strict confidentiality. A principal will respond within one business day.</p>
</div>
</div>
<!-- Sidebar / Protocols & Crisis -->
<div class="lg:col-span-5 flex flex-col gap-gutter">
<!-- Crisis Response -->
<div class="bg-primary-container text-on-primary-container p-8 rounded-lg">
<div class="flex items-center gap-4 mb-6">
<span class="material-symbols-outlined text-secondary-fixed text-4xl">emergency_home</span>
<div>
<h3 class="font-headline-sm text-headline-sm text-white">24/7 Crisis Response</h3>
<p class="font-lp-label-sm text-lp-label-sm uppercase text-on-primary-container/70 tracking-widest">Urgent Global Matters</p>
</div>
</div>
<p class="font-body-md text-on-primary-container/80 mb-6">
                        Immediate counsel for emergency injunctions, regulatory raids, or sensitive reputational crises.
                    </p>
<a class="flex items-center gap-3 text-secondary-fixed font-bold text-xl gold-underline w-fit" href="tel:+1800PRESTIGE">
<span class="material-symbols-outlined">call</span>
                        +1 (800) PRESTIGE
                    </a>
</div>
<!-- Secure Protocol -->
<div class="bg-white p-8 deep-shadow rounded-lg border border-outline-variant/10">
<h3 class="font-headline-sm text-headline-sm mb-4">Secure Communication</h3>
<p class="font-body-md text-on-surface-variant mb-6 leading-relaxed">
                        We employ military-grade encryption for all client communications. Existing clients may access the secure portal for file exchange and real-time case updates.
                    </p>
<div class="flex flex-col gap-4">
<div class="flex items-center gap-4 p-4 bg-surface-container-low rounded">
<span class="material-symbols-outlined text-secondary">encrypted</span>
<span class="font-label-md uppercase">End-to-End Encrypted Portal</span>
</div>
<button class="border border-primary text-primary px-6 py-3 font-label-md uppercase tracking-widest hover:bg-primary hover:text-on-primary transition-all duration-300">
                            Client Access
                        </button>
</div>
</div>
<!-- Office Highlight -->
<div class="grid grid-cols-1 gap-gutter">
<div class="relative h-48 rounded-lg overflow-hidden group">
<div class="w-full h-full bg-cover bg-center transition-transform duration-700 group-hover:scale-110" data-alt="A luxurious, minimalist office building in the center of London's financial district during a misty morning, featuring floor-to-ceiling glass windows and a sleek charcoal steel frame. The lighting is cold and professional, reflecting a high-end litigation firm aesthetic with a palette of deep slates and sharp whites." style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDf4ckNY6m0TxrlrIHaI5aCvpUwV61Z-o6xiSlcd6V9xqP7Kb5ml6jCiXoo8XD18KJWsTqR27P3v6i9JiRp7KS8SQsJ9XxVucAoZ0VEa89EN2G46ig3btE_iVgDiYV8ELEmUd0Mx0X3X9z4eyFIZfN3XJO1qEWS4tGXfGwW-JzStMVmqhH0QFApLtJrg3tWJO4uyIHFD4qT7ggXDyRu47iYJ_Yz0vj24RoJZ2ciAkx-6T1OUn6XzHyopqLAjiS3fsY8zVzh092nRWlE')"></div>
<div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent flex items-end p-6">
<div class="text-white">
<p class="font-lp-label-sm uppercase tracking-widest text-secondary-fixed">Headquarters</p>
<p class="font-headline-sm">London, UK</p>
</div>
</div>
</div>
</div>
</div>
</section>
<!-- Global Locations Section -->
<section class="bg-surface-container-low py-stack-lg">
<div class="max-w-lp-container-max mx-auto px-margin-desktop">
<div class="flex justify-between items-end mb-16">
<div>
<span class="font-lp-label-sm text-lp-label-sm uppercase tracking-[0.3em] text-secondary mb-4 block">Global Presence</span>
<h2 class="font-display-lg text-display-lg">Our Jurisdictions.</h2>
</div>
<div class="hidden md:block w-1/3 h-[1px] bg-outline-variant"></div>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
<!-- London -->
<div class="bg-white p-8 deep-shadow rounded-lg hover-lift">
<h4 class="font-headline-sm text-headline-sm mb-2">London</h4>
<p class="font-lp-label-sm text-lp-label-sm uppercase text-secondary mb-6">Chancery Lane Hub</p>
<p class="font-body-md text-on-surface-variant mb-8">
                            12 Chancery Lane, London WC2A 1PP, United Kingdom.
                        </p>
<div class="h-40 bg-surface-variant mb-6 rounded overflow-hidden">
<img class="w-full h-full object-cover grayscale opacity-80 hover:grayscale-0 transition-all duration-500" data-alt="A clean, minimalist vector map of central London focusing on the Chancery Lane legal district, styled in high-contrast charcoal and pearl white. The aesthetic is sophisticated and executive, with clear sans-serif labels and subtle gold accents for the office location pin." data-location="London" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB6m18NplHgqxNMKengUY-XcGFyhYbxjf3-XcJCJsSL5jcgMTch6mjmVItFVK-bAj8cOmzj0tbhqYfE_ojp6PYKiJeWQGCWHmOUlhhKLMDChWpHmbRTY171JZvbLPZAjmE6UFGT6IDqTqGoQ3DNyefpSLfWM1FygNQXrT_keVTxqlWFcCLvahoE1twZp6WaKe5E_AxldwE4Tuatp3hcJe4iaDCIxSJSJ_7v8XgPU2zF4kwDuo2SnDFMpBjEnKb__UAaTJmYP17VztE6"/>
</div>
<a class="text-primary font-label-md uppercase tracking-widest flex items-center gap-2 group" href="https://www.google.com/maps/search/?api=1&query=12+Chancery+Lane+London+WC2A+1PP+United+Kingdom" target="_blank" rel="noopener">
                            Directions <span class="material-symbols-outlined text-lg group-hover:translate-x-1 transition-transform">arrow_forward</span>
</a>
</div>
<!-- New York -->
<div class="bg-white p-8 deep-shadow rounded-lg hover-lift">
<h4 class="font-headline-sm text-headline-sm mb-2">New York</h4>
<p class="font-lp-label-sm text-lp-label-sm uppercase text-secondary mb-6">Manhattan Chambers</p>
<p class="font-body-md text-on-surface-variant mb-8">
                            767 Fifth Avenue, New York, NY 10153, USA.
                        </p>
<div class="h-40 bg-surface-variant mb-6 rounded overflow-hidden">
<img class="w-full h-full object-cover grayscale opacity-80 hover:grayscale-0 transition-all duration-500" data-alt="A minimalist architectural map of Manhattan's Upper East Side focusing on the Plaza District, featuring a sophisticated monochrome color palette with champagne gold highlights. The visual style is crisp and professional, fitting a top-tier luxury law firm's aesthetic." data-location="New York" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBNwCXnzMFJVyQBxnCp-AFvhbirFn4Cvq3nuvHgHgbTcr8n9ELQ6iheL4ROxdaWrU9ZBfYC8U04czihIxwxR02roiyty9RvbJbM1EuS9FsC0wSqmFqkWuA43EUE4gLUFBGszPRm0AMe1bM26uVKXGIjf5SbPqO9lUFVi8cAwCETe4Yht5kS0xmUtkp0HtVEvSKt1kwUop7vGknMfDc27PSEC_J_cO_R7lK6ckEl5XTb9M0OK1DBB6hwToUKaGd3IZ9YUZWWqjWdvbbr"/>
</div>
<a class="text-primary font-label-md uppercase tracking-widest flex items-center gap-2 group" href="https://www.google.com/maps/search/?api=1&query=767+Fifth+Avenue+New+York+NY+10153+USA" target="_blank" rel="noopener">
                            Directions <span class="material-symbols-outlined text-lg group-hover:translate-x-1 transition-transform">arrow_forward</span>
</a>
</div>
<!-- Singapore -->
<div class="bg-white p-8 deep-shadow rounded-lg hover-lift">
<h4 class="font-headline-sm text-headline-sm mb-2">Singapore</h4>
<p class="font-lp-label-sm text-lp-label-sm uppercase text-secondary mb-6">Marina Bay Suites</p>
<p class="font-body-md text-on-surface-variant mb-8">
                            10 Collyer Quay, Ocean Financial Centre, Singapore.
                        </p>
<div class="h-40 bg-surface-variant mb-6 rounded overflow-hidden">
<img class="w-full h-full object-cover grayscale opacity-80 hover:grayscale-0 transition-all duration-500" data-alt="An executive-style map of Singapore's central business district and Marina Bay, rendered in a minimalist black and white style with elegant, thin line-work. The map uses a champagne gold accent for the office location, conveying a sense of quiet wealth and global authority." data-location="Singapore" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBia3tUbYhyVdEw1wz8J8jFuM6ScjjdrGwuStkXnTygOyhwYh_512fQtVCB7V63vX7B72Q48xcHHoKtN5i33mZ-VrumfOkeO-XIXlDAIgi_d3HulPdy_FwsHJcKaL-iPEFAQcgXWUFX0Y_VPrxZWHLq7eZBkrkZPehr2n1UgmgHpv5-walxhYJpPOkkiufH05qZiEiKPfJq4umPBCNsxC_OJ2XfYoVKRvDz8igf0oCTB1-IXjzCv_NPVevS9AjZKNGYhwFVAsHLxL4K"/>
</div>
<a class="text-primary font-label-md uppercase tracking-widest flex items-center gap-2 group" href="https://www.google.com/maps/search/?api=1&query=10+Collyer+Quay+Ocean+Financial+Centre+Singapore" target="_blank" rel="noopener">
                            Directions <span class="material-symbols-outlined text-lg group-hover:translate-x-1 transition-transform">arrow_forward</span>
</a>
</div>
</div>
</div>
</section>
<!-- Newsletter / Discreet Updates -->
<section class="max-w-lp-container-max mx-auto px-margin-desktop py-stack-lg text-center">
<div class="max-w-2xl mx-auto border-t border-outline-variant pt-stack-lg">
<h3 class="font-lp-headline-md text-lp-headline-md mb-4">Strategic Insights</h3>
<p class="font-body-md text-on-surface-variant mb-8">
                    Monthly briefings on global litigation trends and regulatory shifts, delivered with absolute discretion.
                </p>
<div class="flex flex-col md:flex-row gap-4 justify-center">
<input class="bg-white border-b border-primary px-4 py-3 min-w-[300px] outline-none font-body-md" placeholder="Corporate Email" type="email"/>
<button class="bg-primary text-on-primary px-8 py-3 font-label-md uppercase tracking-widest hover:bg-secondary transition-all">Subscribe</button>
</div>
</div>
</section>
</main>

</TemplateLayout>
