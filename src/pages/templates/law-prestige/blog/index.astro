---
import TemplateLayout from "@/templates/law-prestige/TemplateLayout.astro";
import { blogPosts } from "@/lib/blog";

const posts = blogPosts["law-prestige"];
---

<TemplateLayout
  title="Insights | Prestige Law"
  description="Analysis and perspective on complex commercial litigation, IP enforcement, and regulatory defense from Prestige Law's litigation group."
  active="blog"
  canonicalPath="/templates/law-prestige/blog"
>
<main class="max-w-lp-container-max mx-auto px-margin-desktop py-stack-lg">
<section class="mb-stack-lg max-w-3xl">
<span class="font-lp-label-sm text-lp-label-sm uppercase tracking-[0.3em] text-secondary mb-4 block">Litigation Insights</span>
<h1 class="font-display-lg text-display-lg md:text-[64px] leading-[1.1] mb-8">Perspective.</h1>
<p class="font-body-lg text-body-lg text-on-surface-variant leading-relaxed">Analysis on complex commercial litigation, intellectual property enforcement, and regulatory strategy from Prestige Law's principals.</p>
</section>
<section class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
{posts.map((post) => (
<a href={`/templates/law-prestige/blog/${post.slug}`} class="group bg-surface-container-lowest p-10 deep-shadow rounded-lg border border-outline-variant/10 flex flex-col">
<span class="font-lp-label-sm text-lp-label-sm uppercase tracking-widest text-secondary mb-4 block">{post.category}</span>
<h2 class="font-lp-headline-md text-lp-headline-md mb-4 group-hover:text-secondary transition-colors">{post.title}</h2>
<p class="font-body-md text-on-surface-variant mb-6 flex-grow">{post.excerpt}</p>
<div class="flex items-center justify-between font-lp-label-sm text-lp-label-sm text-outline uppercase tracking-widest pt-4 border-t border-outline-variant/10">
<span>{post.date}</span>
<span>{post.readTime}</span>
</div>
</a>
))}
</section>
</main>
</TemplateLayout>
