---
import TemplateLayout from "@/templates/accounting-archiledger/TemplateLayout.astro";
---

<TemplateLayout
  title="Contact | ARCHI-LEDGER"
  description="Reach ARCHI-LEDGER's managing partners for a structural audit of your enterprise strategy, or send a direct inquiry through our contact form."
  active="contact"
  canonicalPath="/templates/accounting-archiledger/contact"
>
<main class="max-w-container-max mx-auto px-al-margin-mobile md:px-al-margin-desktop py-al-margin-desktop md:py-20">

<section class="grid grid-cols-1 md:grid-cols-12 border-2 border-primary bg-surface-container-low overflow-hidden">
  <!-- Left: Identity & Location -->
  <div class="md:col-span-5 flex flex-col border-b md:border-b-0 md:border-r border-primary">
    <div class="p-8 md:p-12 border-b border-primary bg-surface-container-lowest">
      <h1 class="font-al-headline-xl text-al-headline-lg-mobile md:text-al-headline-xl text-primary mb-4">Connect with Archi-Ledger.</h1>
      <p class="font-al-body-lg text-al-body-lg text-on-surface-variant max-w-md">
        Structural precision for your financial future. Reach out to our partners for a comprehensive audit of your enterprise strategy.
      </p>
    </div>
    <div class="grid grid-cols-1 divide-y divide-primary">
      <div class="p-8 flex items-start gap-6 hover:bg-surface-container transition-colors">
        <span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">location_on</span>
        <div>
          <p class="font-al-label-md text-al-label-md uppercase tracking-widest text-secondary mb-1">Headquarters</p>
          <p class="font-al-body-md text-al-body-md text-on-surface">1244 Financial District, Suite 900<br />New York, NY 10005</p>
        </div>
      </div>
      <div class="p-8 flex items-start gap-6 hover:bg-surface-container transition-colors">
        <span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">call</span>
        <div>
          <p class="font-al-label-md text-al-label-md uppercase tracking-widest text-secondary mb-1">Direct Line</p>
          <p class="font-al-body-md text-al-body-md text-on-surface">+1 (212) 888-ARCHI</p>
        </div>
      </div>
      <div class="p-8 flex items-start gap-6 hover:bg-surface-container transition-colors">
        <span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">mail</span>
        <div>
          <p class="font-al-label-md text-al-label-md uppercase tracking-widest text-secondary mb-1">Email Inquiry</p>
          <p class="font-al-body-md text-al-body-md text-on-surface">partners@archi-ledger.com</p>
        </div>
      </div>
    </div>
    <div class="mt-auto h-80 w-full relative grayscale hover:grayscale-0 transition-all duration-500 overflow-hidden border-t border-primary">
      <img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCeAD_i8_3Idr7sRuJz6e2eoecFIzXbR0c57nKeDya7vnNjImVIHcHmTywcXWasqmX2HnNJJYD9dsT53PuznXUlX_DHmvCFDjgztxViVLd87gxUqcGAh3VzkLeFcnnsMqINvZEbLUKCuqbc2ya1UCcIodFCwjwmiaZzfYnosWB_6-9lri6UE1qrZd3qV_WCKP-x931buTcSv1HAusQp6dXfbqrog9DFBdfrpNyxYOmYRxNSE41uDtm1NpUMYtNjXIycQ7TIFtGrcco" alt="Map view of the New York City financial district near the Archi-Ledger headquarters." loading="lazy" />
      <div class="absolute inset-0 border-4 border-primary pointer-events-none opacity-20"></div>
      <div class="absolute bottom-4 left-4 bg-primary text-on-primary p-2 font-al-label-sm text-al-label-sm uppercase tracking-tighter">NY / 40.7128&deg; N, 74.0060&deg; W</div>
    </div>
  </div>

  <!-- Right: Contact Form -->
  <div class="md:col-span-7 bg-surface-container-lowest p-8 md:p-12">
    <div class="mb-10">
      <h2 class="font-al-headline-lg text-al-headline-lg text-primary uppercase tracking-tight border-b-2 border-primary inline-block pb-1">Inquiry Form</h2>
      <p class="font-al-body-md text-al-body-md text-on-surface-variant mt-4">All fields are monitored by our managing directors. Expect a response within one business cycle.</p>
    </div>
    <form id="contact-form" data-success-target="#contactFormSuccess" class="space-y-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <label class="block font-al-label-md text-al-label-md text-primary uppercase tracking-widest mb-2" for="firstName">First Name</label>
          <input class="w-full h-14 bg-surface px-4 border-2 border-outline-variant focus:border-primary text-primary font-al-body-md outline-none transition-all" id="firstName" name="firstName" placeholder="Alexander" required type="text" />
        </div>
        <div>
          <label class="block font-al-label-md text-al-label-md text-primary uppercase tracking-widest mb-2" for="lastName">Last Name</label>
          <input class="w-full h-14 bg-surface px-4 border-2 border-outline-variant focus:border-primary text-primary font-al-body-md outline-none transition-all" id="lastName" name="lastName" placeholder="Hamilton" required type="text" />
        </div>
      </div>
      <div>
        <label class="block font-al-label-md text-al-label-md text-primary uppercase tracking-widest mb-2" for="email">Corporate Email</label>
        <input class="w-full h-14 bg-surface px-4 border-2 border-outline-variant focus:border-primary text-primary font-al-body-md outline-none transition-all" id="email" name="email" placeholder="a.hamilton@treasury.gov" required type="email" />
      </div>
      <div class="relative">
        <label class="block font-al-label-md text-al-label-md text-primary uppercase tracking-widest mb-2" for="service">Service Selection</label>
        <select class="w-full h-14 bg-surface px-4 border-2 border-outline-variant focus:border-primary text-primary font-al-label-md outline-none transition-all appearance-none" id="service" name="service">
          <option>Institutional Audit</option>
          <option>Tax Strategy &amp; Compliance</option>
          <option>Advisory Services</option>
          <option>Partnership Inquiry</option>
        </select>
        <div class="absolute right-4 top-[50px] pointer-events-none">
          <span class="material-symbols-outlined text-primary">expand_more</span>
        </div>
      </div>
      <div>
        <label class="block font-al-label-md text-al-label-md text-primary uppercase tracking-widest mb-2" for="message">Detailed Inquiry</label>
        <textarea class="w-full bg-surface p-4 border-2 border-outline-variant focus:border-primary text-primary font-al-body-md outline-none transition-all resize-none" id="message" name="message" placeholder="Describe your structural requirements..." required rows="6"></textarea>
      </div>
      <div class="pt-4">
        <button class="w-full md:w-auto bg-primary text-on-primary px-12 py-5 font-al-headline-md text-al-headline-md uppercase tracking-widest hard-shadow hard-shadow-hover transition-all flex items-center justify-center gap-3 active:translate-y-1" type="submit">
          Submit Inquiry
          <span class="material-symbols-outlined">arrow_forward</span>
        </button>
      </div>
    </form>
    <div id="contactFormSuccess" class="hidden text-center py-al-margin-desktop">
      <span class="material-symbols-outlined text-primary text-5xl mb-4">check_circle</span>
      <h3 class="font-al-headline-md text-al-headline-md text-primary mb-2">Transmission Complete</h3>
      <p class="text-on-surface-variant font-al-body-md">Thank you for reaching out. A managing director will respond within one business cycle.</p>
    </div>
  </div>
</section>

<!-- Newsletter Callout -->
<section class="mt-al-margin-desktop md:mt-20 border-2 border-primary bg-primary text-on-primary p-12 text-center">
  <h3 class="font-al-headline-lg text-al-headline-lg uppercase mb-4">The Ledger Insights</h3>
  <p class="font-al-body-lg text-al-body-lg max-w-2xl mx-auto mb-8 opacity-80">Subscribe to our monthly architectural review of the global fiscal landscape.</p>
  <form id="contactNewsletterForm" data-success-target="#contactNewsletterSuccess" class="flex flex-col md:flex-row max-w-xl mx-auto gap-0">
    <input class="flex-grow h-14 bg-on-primary text-primary px-6 border-none font-al-label-md outline-none" placeholder="Email Address" type="email" name="email" required />
    <button type="submit" class="bg-secondary-fixed text-on-secondary-fixed px-10 py-4 font-al-label-md uppercase tracking-widest hover:bg-white transition-colors">Join List</button>
  </form>
  <p id="contactNewsletterSuccess" class="hidden font-al-label-sm text-al-label-sm text-secondary-fixed mt-4">Thanks — you're subscribed.</p>
</section>

</main>
</TemplateLayout>
