---

<TemplateLayout
  title="Services | ARCHI-LEDGER"
  description="Precision-engineered accounting: tax planning & compliance, audit & assurance, business advisory, and forensic accounting from ARCHI-LEDGER."
  active="services"
  canonicalPath="/templates/accounting-archiledger/services"
>
<main class="max-w-container-max mx-auto px-al-margin-mobile md:px-al-margin-desktop py-al-margin-desktop md:py-24">

<section class="mb-al-margin-desktop md:mb-24 border border-primary p-8 md:p-12 bg-surface-container relative overflow-hidden">
  <div class="max-w-3xl relative z-10">
    <h1 class="font-al-headline-xl text-al-headline-lg-mobile md:text-al-headline-xl mb-6 text-primary">Structural Integrity for Financial Success.</h1>
    <p class="font-al-body-lg text-al-body-lg text-on-surface-variant max-w-xl">
      ARCHI-LEDGER provides precision-engineered accounting and advisory services for high-growth enterprises. Our methodology is built on the rigorous principles of architectural planning applied to financial systems.
    </p>
  </div>
</section>

<div class="space-y-0 border-t border-primary">
  {services.map((s) => (
    <section class="grid grid-cols-1 md:grid-cols-2 border-b border-l border-r border-primary">
      <div class:list={["p-8 md:p-12 flex flex-col justify-center bg-white border-primary", s.reverse ? "md:order-2 md:border-l border-t md:border-t-0" : "md:border-r"]}>
        <div class="mb-8 inline-flex items-center justify-center w-12 h-12 border border-primary bg-secondary-container">
          <span class="material-symbols-outlined text-primary">{s.icon}</span>
        </div>
        <h2 class="font-al-headline-lg text-al-headline-lg mb-6 text-primary">{s.title}</h2>
        <ul class="space-y-4 mb-10">
          {s.items.map((item) => (
            <li class="flex items-start">
              <span class="material-symbols-outlined text-primary mr-3 text-[18px]">chevron_right</span>
              <span class="font-al-body-md text-al-body-md">{item}</span>
            </li>
          ))}
        </ul>
        <a href="/templates/accounting-archiledger/contact" class="w-fit px-8 py-3 border-2 border-primary font-al-label-md text-al-label-md uppercase tracking-widest hover:bg-primary hover:text-on-primary transition-all hard-shadow active:translate-y-0.5">Inquire</a>
      </div>
      <div class:list={["h-64 md:h-auto min-h-[400px] relative", s.reverse ? "md:order-1" : ""]}>
        <img class="absolute inset-0 w-full h-full object-cover" src={s.image} alt={s.alt} loading="lazy" />
      </div>
    </section>
  ))}
</div>

<section class="mt-al-margin-desktop md:mt-24 border-2 border-primary p-12 text-center bg-primary text-on-primary">
  <h3 class="font-al-headline-lg text-al-headline-lg mb-4">Ready to Build a Better Foundation?</h3>
  <p class="font-al-body-md text-al-body-md mb-8 opacity-80 max-w-xl mx-auto">Contact our lead partners today for a structural audit of your current accounting practices.</p>
  <div class="flex flex-wrap justify-center gap-4">
    <a href="/templates/accounting-archiledger/contact" class="bg-white text-primary border border-white px-10 py-3 font-al-label-md text-al-label-md uppercase tracking-widest hover:bg-primary-fixed-dim transition-all">Schedule Consultation</a>
    <a href="/templates/accounting-archiledger/about" class="bg-transparent text-white border border-white px-10 py-3 font-al-label-md text-al-label-md uppercase tracking-widest hover:bg-white/10 transition-all">View Case Studies</a>
  </div>
</section>

</main>
</TemplateLayout>
