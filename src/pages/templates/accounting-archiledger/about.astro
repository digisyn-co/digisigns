import TemplateLayout from "@/templates/accounting-archiledger/TemplateLayout.astro";

const values = [
  { icon: "account_balance", title: "Integrity", body: "Uncompromising commitment to ethical transparency. Our audits are built on the bedrock of truth, ensuring every ledger entry reflects objective reality." },
