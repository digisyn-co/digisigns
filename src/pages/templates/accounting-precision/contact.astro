---
import TemplateLayout from "@/templates/accounting-precision/TemplateLayout.astro";
---

<TemplateLayout
  title="Contact Us | TaxPro & Partners"
  description="Reach TaxPro & Partners' global headquarters or send a message — our senior tax strategists respond within one business day."
  active="contact"
  canonicalPath="/templates/accounting-precision/contact"
>
<main class="min-h-screen">
<!-- Hero -->
<section class="relative overflow-hidden py-tp-xl px-margin-mobile md:px-margin-desktop bg-surface-container-low">
<div class="max-w-tp-container-max mx-auto relative z-10">
<div class="max-w-2xl">
<h1 class="font-tp-headline-xl text-tp-headline-lg-mobile md:text-tp-headline-xl text-primary mb-tp-md">Let's get started</h1>
<p class="font-tp-body-lg text-tp-body-lg text-on-surface-variant">Our team of senior tax strategists and financial advisors are ready to help you navigate complex corporate landscapes. Reach out today for a consultation tailored to your unique requirements.</p>
</div>
</div>
</section>
<!-- Two Column Layout -->
<section class="py-tp-xl px-margin-mobile md:px-margin-desktop max-w-tp-container-max mx-auto">
<div class="grid grid-cols-1 lg:grid-cols-2 gap-tp-xl">
<!-- Contact Form -->
<div class="bg-white p-tp-lg rounded-xl corporate-shadow">
<h2 class="font-tp-headline-md text-tp-headline-md text-primary mb-tp-lg">Send us a message</h2>
<form id="contact-form" data-success-target="#contactFormSuccess" class="space-y-tp-md">
<div class="grid grid-cols-1 md:grid-cols-2 gap-tp-md">
<div class="space-y-1">
<label class="font-tp-label-md text-tp-label-md text-on-surface-variant" for="name">Full Name</label>
<input class="w-full px-tp-md py-2 rounded-lg border-[1.5px] border-outline-variant focus:border-secondary focus:ring-2 focus:ring-secondary/20 transition-all outline-none" id="name" name="name" placeholder="John Doe" required type="text" />
</div>
<div class="space-y-1">
<label class="font-tp-label-md text-tp-label-md text-on-surface-variant" for="email">Email Address</label>
<input class="w-full px-tp-md py-2 rounded-lg border-[1.5px] border-outline-variant focus:border-secondary focus:ring-2 focus:ring-secondary/20 transition-all outline-none" id="email" name="email" placeholder="john@company.com" required type="email" />
</div>
</div>
<div class="space-y-1">
<label class="font-tp-label-md text-tp-label-md text-on-surface-variant" for="subject">Subject</label>
<input class="w-full px-tp-md py-2 rounded-lg border-[1.5px] border-outline-variant focus:border-secondary focus:ring-2 focus:ring-secondary/20 transition-all outline-none" id="subject" name="subject" placeholder="Corporate Tax Strategy" required type="text" />
</div>
<div class="space-y-1">
<label class="font-tp-label-md text-tp-label-md text-on-surface-variant" for="message">Message</label>
<textarea class="w-full px-tp-md py-2 rounded-lg border-[1.5px] border-outline-variant focus:border-secondary focus:ring-2 focus:ring-secondary/20 transition-all outline-none resize-none" id="message" name="message" placeholder="How can our experts assist you?" required rows="5"></textarea>
</div>
<button class="w-full bg-primary text-white py-tp-md rounded-lg font-tp-label-md text-tp-label-md hover:bg-secondary-container transition-all active:scale-[0.98]" type="submit">
                            Submit Inquiry
                        </button>
</form>
<div id="contactFormSuccess" class="hidden text-center py-tp-lg">
<span class="material-symbols-outlined text-secondary text-5xl mb-tp-md">check_circle</span>
<h3 class="font-tp-headline-md text-tp-headline-md text-primary mb-2">Message Sent</h3>
<p class="text-on-surface-variant">Thank you for reaching out. A member of our team will respond within one business day.</p>
</div>
</div>
<!-- Info & Map -->
<div class="space-y-tp-lg">
<div class="bg-primary text-on-primary p-tp-lg rounded-xl corporate-shadow">
<h2 class="font-tp-headline-md text-tp-headline-md mb-tp-lg">Global Headquarters</h2>
<div class="space-y-tp-md">
<div class="flex items-start gap-tp-md">
<span class="material-symbols-outlined text-secondary-fixed">location_on</span>
<div>
<p class="font-tp-label-md text-tp-label-md mb-1">Address</p>
<p class="font-tp-body-md text-tp-body-md opacity-80">1200 Financial Plaza, Suite 400<br />New York, NY 10004</p>
</div>
</div>
<div class="flex items-start gap-tp-md">
<span class="material-symbols-outlined text-secondary-fixed">call</span>
<div>
<p class="font-tp-label-md text-tp-label-md mb-1">Phone</p>
<p class="font-tp-body-md text-tp-body-md opacity-80">+1 (212) 555-0198</p>
</div>
</div>
<div class="flex items-start gap-tp-md">
<span class="material-symbols-outlined text-secondary-fixed">mail</span>
<div>
<p class="font-tp-label-md text-tp-label-md mb-1">Email</p>
<p class="font-tp-body-md text-tp-body-md opacity-80">inquiry@taxpropartners.example</p>
</div>
</div>
<div class="flex items-start gap-tp-md">
<span class="material-symbols-outlined text-secondary-fixed">schedule</span>
<div>
<p class="font-tp-label-md text-tp-label-md mb-1">Office Hours</p>
<p class="font-tp-body-md text-tp-body-md opacity-80">Mon — Fri: 8:00 AM - 6:00 PM EST</p>
</div>
</div>
</div>
</div>
<div class="rounded-xl overflow-hidden corporate-shadow h-64 relative group">
<img class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700" alt="A minimalist map view of lower Manhattan, New York City." src="https://lh3.googleusercontent.com/aida-public/AB6AXuBzD0Su4U3Cj817ucTJIcfA_9Eblafn1Ea4IM3E_c-em4222PCGLpu_vSqbfhshbVXfxoAB6BDB6uIKvulv5hbvB0TfxAYzL7y5EnG41Si6KdPVakA0L1V1bWNgJwQpFZV7YeF-sIIIagHzbznAlb2smrP5pLVeqPT3FiYV_N2M0H5v-wh4VtdDBP5Zi6CnTctv2x5KvidzlPbCyHYljy1VH1e9DhrBDPirOnC07-Xcj7SGWELS7kXsswEop66oB5IVYLUNPL2YS4g" />
<div class="absolute inset-0 bg-primary/10 flex items-center justify-center">
<div class="bg-white px-tp-md py-2 rounded-full flex items-center gap-2 shadow-lg">
<span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">location_on</span>
<span class="font-tp-label-md text-tp-label-md text-primary">TaxPro &amp; Partners HQ</span>
</div>
</div>
</div>
</div>
</div>
</section>
<!-- Trust Ticker -->
<section class="bg-surface-container py-tp-md border-y border-outline-variant overflow-hidden">
<div class="max-w-tp-container-max mx-auto px-margin-mobile md:px-margin-desktop flex flex-wrap items-center justify-center gap-tp-lg text-on-surface-variant font-tp-label-md text-tp-label-md">
<span>MEMBER OF THE GLOBAL FINANCE COUNCIL</span>
<span class="w-1 h-1 bg-outline rounded-full"></span>
<span>ISO 27001 CERTIFIED</span>
<span class="w-1 h-1 bg-outline rounded-full"></span>
<span>24/7 CLIENT PORTAL ACCESS</span>
<span class="w-1 h-1 bg-outline rounded-full"></span>
<span>GDPR COMPLIANT DATA PROTECTION</span>
</div>
</section>
</main>
</TemplateLayout>
