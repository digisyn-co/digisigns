---
import TemplateLayout from "@/templates/accounting-precision/TemplateLayout.astro";
import { blogPosts } from "@/lib/blog";

const posts = blogPosts["accounting-precision"].slice(0, 3);
---

<TemplateLayout
  title="TaxPro & Partners | Professional Accounting & Tax Strategy"
  description="Empowering your business with strategic tax planning and comprehensive accounting solutions designed for the modern economy."
  active="home"
  canonicalPath="/templates/accounting-precision"
>
<!-- Hero Section -->
<section class="relative min-h-[600px] md:min-h-[820px] flex items-center overflow-hidden bg-primary-container">
<div class="absolute inset-0 opacity-40">
<div class="absolute inset-0 bg-gradient-to-r from-primary to-transparent z-10"></div>
<img class="w-full h-full object-cover" alt="A sophisticated wide-angle photograph of a modern, glass-walled corporate office interior during the blue hour." src="https://lh3.googleusercontent.com/aida-public/AB6AXuC5LcwOvKpZa8UpcPiectnvzdVAPjTSRXGh1_h5bwPEvBwOEJdWZwkTjhJl3cy_r5jG1GMZ2jzKXpawAkHb1fuvupbKGiIK5xOT6pJNyN-iIaXs3A8mq2_1FDvpdpQy7sIf1cEaBFx4sH58Of7AyGMZ9-gYeQbI589dwxyJAPkHL9hlBaEP-FDJD27SPqLYttUJSEcf5oaT4L6RuVXlJAdB3dvGXnPkS0XPPdda9UVyJozZiNZL-LfeJ99K9EAkEj0d5zOkwrwwDz0" />
</div>
<div class="relative z-20 max-w-tp-container-max mx-auto px-margin-mobile md:px-margin-desktop w-full py-tp-xl grid grid-cols-1 lg:grid-cols-12 gap-gutter">
<div class="lg:col-span-7">
<div class="inline-flex items-center gap-2 bg-secondary/20 text-secondary-fixed px-tp-sm py-tp-xs rounded-full mb-tp-md">
<span class="material-symbols-outlined text-[18px]">verified</span>
<span class="font-tp-label-sm text-tp-label-sm uppercase tracking-wider">Trusted by 500+ Corporations</span>
</div>
<h1 class="font-tp-headline-xl text-tp-headline-lg-mobile md:text-tp-headline-xl text-white mb-tp-md leading-[1.1] text-balance">
                    Precision in Every Number, <span class="text-secondary-fixed">Clarity</span> in Every Decision.
                </h1>
<p class="font-tp-body-lg text-tp-body-lg text-on-primary-container mb-tp-lg max-w-xl">
                    Empowering your business with strategic tax planning and comprehensive accounting solutions designed for the modern economy.
                </p>
<div class="flex flex-wrap gap-tp-md">
<a href="/templates/accounting-precision/contact" class="bg-secondary text-on-secondary px-tp-xl py-tp-md rounded-lg font-tp-label-md text-tp-label-md hover:scale-[1.02] transition-transform corporate-shadow inline-block text-center">
                        Book a Consultation
                    </a>
<a href="/templates/accounting-precision/services" class="border-[1.5px] border-on-primary-container text-white px-tp-xl py-tp-md rounded-lg font-tp-label-md text-tp-label-md hover:bg-white/10 transition-colors inline-block text-center">
                        Explore Services
                    </a>
</div>
</div>
</div>
</section>
<!-- Trust Bar -->
<section class="bg-surface-container-low py-tp-lg border-b border-outline-variant/30">
<div class="max-w-tp-container-max mx-auto px-margin-mobile md:px-margin-desktop">
<p class="text-center font-tp-label-sm text-tp-label-sm text-on-surface-variant/60 uppercase tracking-widest mb-tp-md">Certified Partners &amp; Recognition</p>
<div class="flex flex-wrap justify-center items-center gap-tp-xl opacity-50 grayscale hover:grayscale-0 transition-all duration-500">
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-tp-headline-md">account_balance</span>
<span class="font-bold">FINANCE WEEKLY</span>
</div>
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-tp-headline-md">award_star</span>
<span class="font-bold">TAX LEADERS</span>
</div>
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-tp-headline-md">verified_user</span>
<span class="font-bold">AICPA CERTIFIED</span>
</div>
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-tp-headline-md">analytics</span>
<span class="font-bold">STRATEGY 500</span>
</div>
</div>
</div>
</section>
<!-- Why Choose Us Section (Bento Style) -->
<section class="py-tp-xl bg-surface">
<div class="max-w-tp-container-max mx-auto px-margin-mobile md:px-margin-desktop">
<div class="mb-tp-xl max-w-2xl reveal-on-scroll">
<h2 class="font-tp-headline-lg text-tp-headline-lg text-primary mb-tp-md">Superior Financial Stewardship</h2>
<p class="font-tp-body-md text-tp-body-md text-on-surface-variant">We bridge the gap between traditional accounting excellence and contemporary business agility.</p>
</div>
<div class="grid grid-cols-1 md:grid-cols-12 gap-gutter">
<div class="md:col-span-8 bg-white p-tp-lg rounded-xl corporate-shadow flex flex-col md:flex-row gap-tp-lg items-center group reveal-on-scroll">
<div class="w-full md:w-1/2 overflow-hidden rounded-lg h-64">
<img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" alt="Two business partners shaking hands in a bright corporate lobby." src="https://lh3.googleusercontent.com/aida-public/AB6AXuAtkKSKD4pLsmu05qTJxOC3W_YHzCTOSherNrKXeei7AYjEHJrjZ9iKVlgh3y-G3O1GYS67CE2AJsrsMprt19IeYO23P38tVcsvfKlgWIiS5L2_osmQJSxcfdZUfgQBD9T54okzVkHlO_ZJreNuw29jfoWSaMwiXE6NRBu_2Ha0Wvc5U-u0oaaUUQV0WKkzIYa9S8irYWSByr4AIUP-N8bvtoJqOwXagbxGBKGt2Zb53sigVkOeOCPJ2xd6E9FWrcbbEHIrQRMaAB8" />
</div>
<div class="w-full md:w-1/2">
<span class="material-symbols-outlined text-secondary text-[40px] mb-2">history_edu</span>
<h3 class="font-tp-headline-md text-tp-headline-md text-primary mb-2">Decades of Expertise</h3>
<p class="text-on-surface-variant font-tp-body-md">Our senior partners bring over 30 years of navigating complex tax codes and corporate structuring for Fortune 500 clients.</p>
</div>
</div>
<div class="md:col-span-4 bg-primary p-tp-lg rounded-xl text-white flex flex-col justify-between overflow-hidden relative reveal-on-scroll">
<div class="relative z-10">
<span class="material-symbols-outlined text-secondary-fixed text-[40px] mb-2">person_celebrate</span>
<h3 class="font-tp-headline-md text-tp-headline-md mb-2">Tailored Solutions</h3>
<p class="opacity-80 font-tp-body-md">Every client is a unique ecosystem. We don't believe in templates; we believe in bespoke strategy.</p>
</div>
<div class="mt-tp-lg relative z-10">
<a class="text-secondary-fixed font-tp-label-md flex items-center gap-1 hover:gap-3 transition-all" href="/templates/accounting-precision/about">
                                Learn More <span class="material-symbols-outlined">arrow_forward</span>
</a>
</div>
<div class="absolute -bottom-10 -right-10 opacity-10">
<span class="material-symbols-outlined text-[200px]">diversity_3</span>
</div>
</div>
<div class="md:col-span-4 bg-surface-container-high p-tp-lg rounded-xl border border-outline-variant/50 reveal-on-scroll">
<span class="material-symbols-outlined text-secondary text-[40px] mb-2">data_exploration</span>
<h3 class="font-tp-headline-md text-tp-headline-md text-primary mb-2">Advanced Tech</h3>
<p class="text-on-surface-variant font-tp-body-md mb-tp-md">Real-time cloud analytics and AI-driven predictive tax modeling for proactive decision making.</p>
<div class="w-full h-32 rounded-lg bg-white p-2 corporate-shadow">
<div class="flex items-end gap-1 h-full">
<div class="bg-secondary-container w-full h-[40%] rounded-t-sm"></div>
<div class="bg-secondary w-full h-[65%] rounded-t-sm"></div>
<div class="bg-secondary-container w-full h-[50%] rounded-t-sm"></div>
<div class="bg-primary w-full h-[90%] rounded-t-sm"></div>
<div class="bg-secondary w-full h-[75%] rounded-t-sm"></div>
</div>
</div>
</div>
<div class="md:col-span-8 bg-white p-tp-lg rounded-xl corporate-shadow flex flex-col justify-center reveal-on-scroll">
<div class="flex items-center gap-tp-md">
<div class="bg-surface-container rounded-full p-tp-md">
<span class="material-symbols-outlined text-secondary text-[32px]">public</span>
</div>
<div>
<h3 class="font-tp-headline-md text-tp-headline-md text-primary mb-1">International Reach</h3>
<p class="text-on-surface-variant font-tp-body-md">Coordinating cross-border tax compliance across 40+ jurisdictions seamlessly.</p>
</div>
</div>
</div>
</div>
</div>
</section>
<!-- Latest Insights / Blog Preview -->
<section class="py-tp-xl bg-surface-container-low">
<div class="max-w-tp-container-max mx-auto px-margin-mobile md:px-margin-desktop">
<div class="flex justify-between items-end mb-tp-xl">
<div>
<h2 class="font-tp-headline-lg text-tp-headline-lg text-primary mb-2">Strategic Insights</h2>
<p class="font-tp-body-md text-tp-body-md text-on-surface-variant">Stay ahead of legislative changes and market shifts.</p>
</div>
<a class="hidden md:flex items-center gap-1 text-secondary font-tp-label-md hover:underline" href="/templates/accounting-precision/blog">
                        View All Articles <span class="material-symbols-outlined">open_in_new</span>
</a>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
{posts.map((post) => (
  <a href={`/templates/accounting-precision/blog/${post.slug}`} class="group cursor-pointer block">
    <div class="relative h-64 overflow-hidden rounded-xl mb-tp-md bg-surface-container-high flex items-center justify-center">
      <span class="material-symbols-outlined text-primary/20 text-[64px]">description</span>
      <div class="absolute top-2 left-2">
        <span class="bg-white/90 backdrop-blur px-2 py-1 rounded font-tp-label-sm text-tp-label-sm text-primary">{post.category}</span>
      </div>
    </div>
    <span class="text-on-surface-variant font-tp-label-sm text-tp-label-sm">{post.date}</span>
    <h4 class="font-tp-headline-md text-[20px] text-primary mt-1 mb-2 group-hover:text-secondary transition-colors">{post.title}</h4>
    <p class="text-on-surface-variant line-clamp-2">{post.excerpt}</p>
  </a>
))}
</div>
</div>
</section>
<!-- CTA Section -->
<section class="py-tp-xl">
<div class="max-w-tp-container-max mx-auto px-margin-mobile md:px-margin-desktop">
<div class="bg-primary rounded-xl p-tp-lg md:p-tp-xl text-center relative overflow-hidden">
<div class="relative z-10">
<h2 class="font-tp-headline-xl text-tp-headline-lg-mobile md:text-tp-headline-xl text-white mb-tp-md">Ready to Optimize Your Financial Future?</h2>
<p class="font-tp-body-lg text-tp-body-lg text-secondary-fixed mb-tp-lg max-w-2xl mx-auto">Join the hundreds of businesses that rely on TaxPro &amp; Partners for uncompromising accuracy and strategic vision.</p>
<a href="/templates/accounting-precision/contact" class="bg-secondary text-on-secondary px-tp-xl py-tp-md rounded-lg font-tp-label-md text-tp-label-md hover:scale-105 transition-transform corporate-shadow inline-block">
                            Book Your Free Consultation
                        </a>
</div>
<div class="absolute top-0 right-0 w-64 h-64 bg-secondary/10 rounded-full blur-3xl -mr-32 -mt-32"></div>
<div class="absolute bottom-0 left-0 w-64 h-64 bg-secondary/10 rounded-full blur-3xl -ml-32 -mb-32"></div>
</div>
</div>
</section>
</TemplateLayout>
