<div class="max-w-tp-container-max mx-auto px-margin-mobile md:px-margin-desktop">
<div class="grid md:grid-cols-2 gap-tp-xl items-center">
<div class="relative reveal-on-scroll">
<div class="absolute -top-10 -left-10 w-40 h-40 bg-secondary/10 rounded-full blur-3xl"></div>
<div class="relative bg-white p-tp-lg rounded-xl corporate-shadow border border-outline-variant/20">
<span class="material-symbols-outlined text-secondary text-5xl mb-tp-md" style="font-variation-settings: 'FILL' 1;">format_quote</span>
<p class="font-tp-headline-md text-tp-headline-md italic text-primary mb-tp-lg">
