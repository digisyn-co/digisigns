</div>
</div>
</div>
</div>
</div>
</section>
<!-- CTA -->
<section class="py-tp-xl bg-primary text-on-primary text-center">
<div class="max-w-3xl mx-auto px-margin-mobile">
<h2 class="font-tp-headline-lg text-tp-headline-lg mb-tp-md">Ready for Industry-Specific Strategy?</h2>
<p class="font-tp-body-lg text-tp-body-lg text-on-primary-container mb-tp-xl">Schedule a consultation with a specialist who understands the unique nuances of your business sector.</p>
<a href="/templates/accounting-precision/contact" class="bg-secondary text-white px-tp-xl py-tp-md rounded-lg font-tp-label-md text-tp-label-md hover:bg-secondary-container transition-all shadow-lg inline-block">
