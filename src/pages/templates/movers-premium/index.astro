<script>
  function slideTestimonial(direction: number) {
    const slider = document.getElementById("testimonial-slider");
    if (!slider) return;
    const card = slider.querySelector(":scope > div");
    const cardWidth = card instanceof HTMLElement ? card.offsetWidth + 24 : slider.clientWidth;
    slider.scrollBy({ left: direction * cardWidth, behavior: "smooth" });
  }
  // @ts-ignore -- exposed for the inline onclick="" handlers in this page
  window.slideTestimonial = slideTestimonial;
</script>
</TemplateLayout>
