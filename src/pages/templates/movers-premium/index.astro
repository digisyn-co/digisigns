---
import TemplateLayout from "@/templates/movers-premium/TemplateLayout.astro";
---

<TemplateLayout
  title="RapidRelo Moving & Storage | Fast, Simple, Stress-Free"
  description="Get an instant moving quote in 60 seconds. RapidRelo handles local, long-distance, and commercial relocations with precision logistics."
  active="home"
  canonicalPath="/templates/movers-premium"
>
<main>
<!-- Hero Section -->
<section class="relative min-h-[819px] flex items-center pt-24 pb-12 overflow-hidden">
<div class="absolute inset-0 z-0 bg-surface-container-low opacity-50">
<!-- Atmospheric background element -->
<div class="absolute right-0 top-0 w-1/2 h-full bg-primary opacity-10 skew-x-12 translate-x-1/4"></div>
</div>
<div class="container max-w-rr-container-max mx-auto px-rr-margin-mobile md:px-rr-margin-desktop relative z-10">
<div class="grid grid-cols-1 lg:grid-cols-12 gap-rr-stack-lg items-center">
<div class="lg:col-span-6 space-y-stack-md">
<h1 class="font-rr-display-lg text-rr-display-lg-mobile md:text-rr-display-lg text-on-surface leading-none">
                            MOVING MADE <span class="text-primary-fixed-dim bg-on-surface px-2">FAST</span>, SIMPLE, &amp; STRESS-FREE.
                        </h1>
<p class="font-body-lg text-body-lg text-on-surface-variant max-w-lg">
                            Ditch the moving day dread. Get an instant quote in 60 seconds with our precision calculator.
                        </p>
</div>
<!-- Quote Calculator Widget -->
<div class="lg:col-span-6">
<div class="bg-surface-container-lowest border-2 border-on-surface p-rr-stack-lg block-shadow">
<div class="bg-primary-container h-8 -mt-rr-stack-lg -mx-rr-stack-lg mb-rr-stack-lg border-b-2 border-on-surface flex items-center px-4">
<span class="font-label-bold text-label-bold uppercase text-on-primary-fixed">Instant Quote Calculator</span>
</div>
<form class="space-y-stack-md">
<div class="grid grid-cols-2 gap-stack-md">
<div class="space-y-stack-sm">
<label class="font-label-bold text-label-bold uppercase block text-on-surface">From ZIP</label>
<input class="w-full border-2 border-on-surface px-4 py-3 focus:border-primary-container focus:ring-0 outline-none" placeholder="e.g. 90210" type="text"/>
</div>
<div class="space-y-stack-sm">
<label class="font-label-bold text-label-bold uppercase block text-on-surface">To ZIP</label>
<input class="w-full border-2 border-on-surface px-4 py-3 focus:border-primary-container focus:ring-0 outline-none" placeholder="e.g. 10001" type="text"/>
</div>
</div>
<div class="space-y-stack-sm">
<label class="font-label-bold text-label-bold uppercase block text-on-surface">Size of Home</label>
<select class="w-full border-2 border-on-surface px-4 py-3 focus:border-primary-container focus:ring-0 outline-none appearance-none">
<option>Studio / 1 Bedroom</option>
<option>2-3 Bedroom Home</option>
<option>4+ Bedroom Home</option>
<option>Office / Commercial</option>
</select>
</div>
<button class="w-full bg-primary-container text-on-primary-fixed font-rr-display-lg text-rr-headline-sm uppercase py-4 border-2 border-on-surface block-shadow-hover transition-all active:translate-y-1" id="quoteCalcButton" type="button">
                                    Calculate My Quote
                                </button>
<p class="text-center font-rr-label-sm text-rr-label-sm opacity-60 italic">
                                    *No credit card required for estimate.
                                </p>
</form>
<div class="hidden text-center py-4" id="quoteCalcResult">
<p class="font-label-bold text-label-sm uppercase text-on-surface-variant mb-2">Estimated Range</p>
<p class="font-rr-display-lg text-rr-headline-sm text-primary mb-4" id="quoteCalcAmount">$1,200 &ndash; $2,400</p>
<a href="/templates/movers-premium/contact" class="inline-block bg-on-surface text-white font-label-bold text-label-sm uppercase px-6 py-3 border-2 border-on-surface hover:bg-primary-container hover:text-on-surface transition-all">Lock In This Quote</a>
</div>
</div>
</div>
</div>
</div>
</section>
<script>
  const quoteBtn = document.getElementById("quoteCalcButton");
  if (quoteBtn) {
    quoteBtn.addEventListener("click", () => {
      const sizeSelect = document.querySelector<HTMLSelectElement>('select');
      const ranges: Record<string, string> = {
        "Studio / 1 Bedroom": "$800 \u2013 $1,500",
        "2-3 Bedroom Home": "$1,600 \u2013 $3,200",
        "4+ Bedroom Home": "$3,400 \u2013 $6,500",
        "Office / Commercial": "$2,800 \u2013 $9,000",
      };
      const size = sizeSelect?.value ?? "2-3 Bedroom Home";
      const amountEl = document.getElementById("quoteCalcAmount");
      if (amountEl) amountEl.textContent = ranges[size] ?? "$1,600 \u2013 $3,200";
      const form = quoteBtn.closest("form");
      const result = document.getElementById("quoteCalcResult");
      if (form) form.classList.add("hidden");
      if (result) result.classList.remove("hidden");
    });
  }
</script>
<!-- Trust Bar -->
