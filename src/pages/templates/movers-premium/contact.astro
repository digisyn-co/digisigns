---
import TemplateLayout from "@/templates/movers-premium/TemplateLayout.astro";
---

<TemplateLayout
  title="Contact Us | RapidRelo Moving & Storage"
  description="Start your booking or reach RapidRelo's emergency moving line."
  active="contact"
  canonicalPath="/templates/movers-premium/contact"
>
<main class="w-full">
<!-- Hero Section -->
<section class="bg-surface py-rr-stack-lg border-b-2 border-on-surface">
<div class="max-w-rr-container-max mx-auto px-rr-margin-mobile md:px-rr-margin-desktop">
<div class="flex flex-col md:flex-row justify-between items-end gap-stack-md">
<div class="max-w-2xl">
<div class="inline-flex items-center gap-2 bg-primary-container px-3 py-1 border-2 border-on-surface mb-stack-sm">
<span class="material-symbols-outlined text-sm" data-weight="fill">verified</span>
<span class="font-label-bold text-rr-label-sm uppercase">Official Contact Center</span>
</div>
<h1 class="font-rr-display-lg text-rr-display-lg-mobile md:text-rr-display-lg text-on-surface">
                            LET'S GET YOU MOVING.
                        </h1>
</div>
<div class="flex gap-4 mb-2">
<div class="flex flex-col items-center">
<div class="w-16 h-16 border-2 border-on-surface flex items-center justify-center bg-white block-shadow">
<span class="material-symbols-outlined text-3xl">shield</span>
</div>
<span class="font-label-bold text-rr-label-sm uppercase mt-2">Licensed</span>
</div>
<div class="flex flex-col items-center">
<div class="w-16 h-16 border-2 border-on-surface flex items-center justify-center bg-white block-shadow">
<span class="material-symbols-outlined text-3xl">star</span>
</div>
<span class="font-label-bold text-rr-label-sm uppercase mt-2">Top Rated</span>
</div>
</div>
</div>
</div>
</section>
<!-- Booking & Emergency Section -->
<section class="py-rr-stack-lg px-rr-margin-mobile md:px-rr-margin-desktop max-w-rr-container-max mx-auto">
<div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
<!-- Left: Wizard Booking Flow -->
<div class="lg:col-span-8">
<div class="bg-white border-2 border-on-surface relative overflow-hidden h-full">
<div class="h-8 bg-primary-container border-b-2 border-on-surface flex items-center px-4">
<span class="font-label-bold text-rr-label-sm uppercase">Booking Wizard v2.0</span>
</div>
<div class="p-rr-stack-lg">
<!-- Progress Bar -->
<div class="w-full h-4 bg-surface-container-highest border-2 border-on-surface mb-rr-stack-lg flex">
<div class="h-full bg-primary-container border-r-2 border-on-surface transition-all duration-500" id="progress-bar" style="width: 33%"></div>
</div>
<form id="booking-wizard">
<!-- Step 1: Logistics -->
<div class="step-content" id="step-1">
<h2 class="font-rr-headline-md text-rr-headline-md mb-stack-md uppercase">1. Logistics</h2>
<div class="grid grid-cols-1 md:grid-cols-2 gap-stack-md">
<div>
<label class="font-label-bold text-label-bold uppercase block mb-stack-sm">Date of Move</label>
<input class="w-full border-2 border-on-surface p-4 focus:ring-0 focus:border-primary-container outline-none font-rr-body-md" type="date"/>
</div>
<div>
<label class="font-label-bold text-label-bold uppercase block mb-stack-sm">Type of Service</label>
<select class="w-full border-2 border-on-surface p-4 focus:ring-0 focus:border-primary-container outline-none font-rr-body-md appearance-none">
<option>Local Residential</option>
<option>Long Distance</option>
<option>Commercial Office</option>
<option>Storage Solutions</option>
</select>
</div>
</div>
<button class="mt-rr-stack-lg bg-on-surface text-white font-label-bold text-label-bold uppercase px-8 py-4 border-2 border-on-surface block-shadow hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all w-full md:w-auto" onclick="nextStep(2)" type="button">
                                        Next: Your Details
                                    </button>
</div>
<!-- Step 2: Contact (Hidden) -->
<div class="step-content hidden" id="step-2">
<h2 class="font-rr-headline-md text-rr-headline-md mb-stack-md uppercase">2. Contact Details</h2>
<div class="grid grid-cols-1 md:grid-cols-2 gap-stack-md">
<div>
<label class="font-label-bold text-label-bold uppercase block mb-stack-sm">Full Name</label>
<input class="w-full border-2 border-on-surface p-4 focus:ring-0 focus:border-primary-container outline-none font-rr-body-md" placeholder="John Doe" type="text"/>
</div>
<div>
<label class="font-label-bold text-label-bold uppercase block mb-stack-sm">Phone Number</label>
<input class="w-full border-2 border-on-surface p-4 focus:ring-0 focus:border-primary-container outline-none font-rr-body-md" placeholder="(555) 000-0000" type="tel"/>
</div>
</div>
<div class="flex gap-4 mt-rr-stack-lg">
<button class="border-2 border-on-surface font-label-bold text-label-bold uppercase px-8 py-4 hover:bg-surface-variant transition-all" onclick="nextStep(1)" type="button">Back</button>
<button class="bg-on-surface text-white font-label-bold text-label-bold uppercase px-8 py-4 border-2 border-on-surface block-shadow hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all grow" onclick="nextStep(3)" type="button">Next: Inventory</button>
</div>
</div>
<!-- Step 3: Confirmation (Hidden) -->
<div class="step-content hidden" id="step-3">
<h2 class="font-rr-headline-md text-rr-headline-md mb-stack-md uppercase">3. Final Check</h2>
<div class="p-4 bg-surface-container border-2 border-on-surface border-dashed mb-rr-stack-lg">
<p class="font-rr-body-md italic text-on-surface-variant">Ready to secure your slot? Our agents will review your data and call back within 15 minutes during business hours.</p>
</div>
<div class="flex gap-4">
<button class="border-2 border-on-surface font-label-bold text-label-bold uppercase px-8 py-4 hover:bg-surface-variant transition-all" onclick="nextStep(2)" type="button">Back</button>
<button class="bg-primary-container text-on-surface font-label-bold text-label-bold uppercase px-8 py-4 border-2 border-on-surface block-shadow hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all grow" type="submit">Get My Moving Quote</button>
</div>
</div>
<!-- Confirmation (Hidden until submit) -->
<div class="step-content hidden text-center py-8" id="step-done">
<span class="material-symbols-outlined text-6xl text-primary-container mb-4">task_alt</span>
<h2 class="font-rr-headline-md text-rr-headline-md mb-stack-sm uppercase">Quote Requested.</h2>
<p class="font-rr-body-md text-on-surface-variant max-w-sm mx-auto">An agent will call you back within 15 minutes during business hours to confirm your move.</p>
</div>
</form>
</div>
</div>
</div>
<!-- Right: Emergency & Map -->
<div class="lg:col-span-4 flex flex-col gap-gutter">
<!-- Hotline Card -->
<div class="bg-error text-on-error p-rr-stack-lg border-2 border-on-surface block-shadow">
<div class="flex items-center gap-2 mb-stack-sm">
<span class="material-symbols-outlined text-white animate-pulse" data-weight="fill">emergency</span>
<h3 class="font-label-bold text-label-bold uppercase">Last Minute Move?</h3>
</div>
<p class="font-rr-headline-md text-rr-headline-md mb-stack-md leading-none">CALL THE HOTLINE</p>
<a class="block text-center bg-white text-error font-rr-display-lg text-rr-display-lg-mobile py-4 border-2 border-on-surface hover:bg-primary-container hover:text-on-surface transition-colors" href="tel:1800RAPIDRE">
                            1-800-RAPID-RE
                        </a>
<p class="text-rr-label-sm font-label-bold uppercase mt-stack-sm opacity-80 text-center">Available 24/7 for Emergency Dispatch</p>
</div>
<!-- Location Card -->
<div class="bg-white border-2 border-on-surface flex-grow flex flex-col">
<div class="h-48 relative overflow-hidden border-b-2 border-on-surface">
<div class="bg-cover bg-center w-full h-full" data-alt="A clean, minimalist vector-style map of a city grid in high-contrast gray and white tones, with a bright primary yellow circular overlay indicating a service coverage radius. A single black pin marker represents the headquarters location. The design is modern, professional, and consistent with a high-velocity logistics brand." data-location="Chicago" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBiTns6L7Rup8vnH-DWxGi9jK6_hZoJMwfE3QUzQq-DWnrygul_Cdu11LwGakGKcyua66N64DOwfDNgVWy4yPLZThcvRyThAclMrDfjUrrEsSMFLxDoiasxhAdMx3NDhk-sinmbpDoicKkQewpyd32rrotWHzAaNA4BRJ5Zp9KMqpWg1lihjel2F4e20nsROkf68Ozxr2x6Y6F1wIUTMCfS2dc-XZqLyOQMfK6LAOKzFDa2ltI9MhDCJwfzKLU9tt1MaOQyExX47P9V')"></div>
<div class="absolute inset-0 bg-primary-container/10"></div>
</div>
<div class="p-stack-md">
<h4 class="font-label-bold text-label-bold uppercase mb-2">Global Headquarters</h4>
<p class="text-on-surface-variant">123 Logistics Way, Suite 400<br/>Chicago, IL 60601</p>
<hr class="my-stack-sm border-on-surface opacity-20"/>
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-primary">distance</span>
<span class="text-rr-label-sm font-label-bold uppercase">50 Mile Service Radius</span>
</div>
</div>
</div>
</div>
</div>
</section>
<!-- FAQ Section -->
<section class="bg-surface-container py-rr-stack-lg">
<div class="max-w-rr-container-max mx-auto px-rr-margin-mobile md:px-rr-margin-desktop">
<div class="flex flex-col md:flex-row gap-gutter">
<div class="md:w-1/3">
<h2 class="font-rr-display-lg text-rr-display-lg-mobile md:text-rr-display-lg uppercase leading-tight mb-stack-sm">Common<br/>Questions</h2>
<p class="text-on-surface-variant max-w-xs">Need answers fast? Here are the most frequent inquiries from our clients.</p>
</div>
<div class="md:w-2/3 space-y-stack-md">
<div class="bg-white border-2 border-on-surface p-stack-md">
<h3 class="font-label-bold text-label-bold uppercase mb-2 flex items-center justify-between">
                                How do you calculate pricing?
                                <span class="material-symbols-outlined">expand_more</span>
</h3>
<p class="font-rr-body-md text-on-surface-variant">Pricing is based on a transparent combination of inventory volume, distance, and chosen labor tiers. No hidden fuel surcharges, ever.</p>
</div>
<div class="bg-white border-2 border-on-surface p-stack-md">
<h3 class="font-label-bold text-label-bold uppercase mb-2 flex items-center justify-between">
                                Is my furniture insured?
                                <span class="material-symbols-outlined">expand_more</span>
</h3>
<p class="font-rr-body-md text-on-surface-variant">Yes. Every RapidRelo move includes standard valuation coverage. We also offer Premium Replacement Value protection for high-end items.</p>
</div>
<div class="bg-white border-2 border-on-surface p-stack-md">
<h3 class="font-label-bold text-label-bold uppercase mb-2 flex items-center justify-between">
                                What is the 'Rapid' guarantee?
                                <span class="material-symbols-outlined">expand_more</span>
</h3>
<p class="font-rr-body-md text-on-surface-variant">If we're late to your pickup window by more than 30 minutes, we deduct 10% from your total labor bill automatically.</p>
</div>
</div>
</div>
</div>
</section>
</main>

<script>
  function nextStep(step: number) {
    document.querySelectorAll(".step-content").forEach((el) => el.classList.add("hidden"));
    const target = document.getElementById(step === 4 ? "step-done" : `step-${step}`);
    if (target) target.classList.remove("hidden");
    const bar = document.getElementById("progress-bar");
    if (bar) bar.style.width = `${Math.min(step, 3) * 33}%`;
  }
  // @ts-ignore -- exposed for the inline onclick="" handlers in this page
  window.nextStep = nextStep;

  const wizard = document.getElementById("booking-wizard");
  if (wizard) {
    wizard.addEventListener("submit", (e) => {
      e.preventDefault();
      nextStep(4);
    });
  }
</script>
</TemplateLayout>
