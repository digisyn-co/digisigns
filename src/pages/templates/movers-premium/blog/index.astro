---
import TemplateLayout from "@/templates/movers-premium/TemplateLayout.astro";
import { blogPosts } from "@/lib/blog";

const posts = blogPosts["movers-premium"];
---

<TemplateLayout
  title="Moving Tips | RapidRelo Moving & Storage"
  description="Practical moving advice, pricing breakdowns, and packing guides from the RapidRelo team."
  active="blog"
  canonicalPath="/templates/movers-premium/blog"
>
<main class="w-full">
<section class="bg-surface py-rr-stack-lg border-b-2 border-on-surface">
<div class="max-w-rr-container-max mx-auto px-rr-margin-mobile md:px-rr-margin-desktop">
<h1 class="font-rr-display-lg text-rr-display-lg-mobile md:text-rr-display-lg text-on-surface mb-4">MOVING TIPS &amp; GUIDES</h1>
<p class="font-rr-body-md text-on-surface-variant max-w-2xl">Straight-talk advice on pricing, packing, and planning your move — no fluff, just what actually helps.</p>
</div>
</section>
<section class="py-rr-stack-lg px-rr-margin-mobile md:px-rr-margin-desktop max-w-rr-container-max mx-auto">
<div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
{posts.map((post) => (
<a href={`/templates/movers-premium/blog/${post.slug}`} class="group bg-white border-2 border-on-surface p-rr-stack-lg block-shadow block-shadow-hover transition-all flex flex-col">
<span class="font-label-bold text-rr-label-sm uppercase bg-primary-container inline-block px-3 py-1 mb-4 w-fit">{post.category}</span>
<h2 class="font-rr-headline-sm text-rr-headline-sm uppercase mb-4">{post.title}</h2>
<p class="font-rr-body-md text-on-surface-variant mb-6 flex-grow">{post.excerpt}</p>
<div class="flex items-center justify-between font-label-bold text-rr-label-sm uppercase text-on-surface-variant pt-4 border-t-2 border-on-surface">
<span>{post.date}</span>
<span>{post.readTime}</span>
</div>
</a>
))}
</div>
</section>
</main>
</TemplateLayout>
