---
import TemplateLayout from "@/templates/creative-studio/TemplateLayout.astro";
---

<TemplateLayout
  title="Services | The Creative Collective"
  description="Brand identity, digital campaigns, and creative direction — the full toolkit for transformation."
  active="services"
  canonicalPath="/templates/creative-studio/services"
>
<main>
<!-- Hero Section -->
<section class="relative pt-24 pb-32 overflow-hidden hero-glow">
<div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop text-center">
<div class="inline-block px-4 py-1 mb-6 rounded-full bg-secondary-fixed text-on-secondary-fixed font-cs-label-md text-cs-label-md uppercase tracking-widest">
                    Expertise Unleashed
                </div>
<h1 class="font-cs-display-lg text-cs-display-lg-mobile md:text-cs-display-lg mb-8 text-on-surface max-w-4xl mx-auto leading-none">
                    Our Toolkit for <span class="text-transparent bg-clip-text gradient-btn">Transformation.</span>
</h1>
<p class="font-cs-body-lg text-cs-body-lg text-on-surface-variant max-w-2xl mx-auto mb-12">
                    We don't just build assets; we engineer experiences that fuel your creative spark and drive undeniable market impact.
                </p>
<div class="w-full h-1 bg-outline-variant/20 rounded-full max-w-xs mx-auto"></div>
</div>
</section>
<!-- Service Cards Grid -->
<section class="py-24 bg-surface-bright">
<div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
<!-- Brand Identity -->
<div class="group bg-white p-8 rounded-[24px] border border-outline-variant/30 vibrant-shadow hover:translate-y-[-8px] transition-all duration-500">
<div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
<span class="material-symbols-outlined text-primary text-4xl" data-icon="shape_line">shape_line</span>
</div>
<h3 class="font-cs-headline-md text-cs-headline-md mb-4 text-on-surface">Brand Identity</h3>
<p class="text-on-surface-variant mb-6 leading-relaxed">Defining your visual DNA with striking logos, typography, and cohesive guidelines that command attention.</p>
<div class="flex items-center text-primary font-bold group-hover:gap-2 transition-all">
                            Explore <span class="material-symbols-outlined ml-1">arrow_forward</span>
</div>
</div>
<!-- Web Design -->
<div class="group bg-white p-8 rounded-[24px] border border-outline-variant/30 vibrant-shadow hover:translate-y-[-8px] transition-all duration-500">
<div class="w-16 h-16 rounded-2xl bg-secondary/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
<span class="material-symbols-outlined text-secondary text-4xl" data-icon="web">web</span>
</div>
<h3 class="font-cs-headline-md text-cs-headline-md mb-4 text-on-surface">Web Design</h3>
<p class="text-on-surface-variant mb-6 leading-relaxed">High-performance digital homes built on kinetic layouts, modern minimalism, and technical excellence.</p>
<div class="flex items-center text-secondary font-bold group-hover:gap-2 transition-all">
                            Explore <span class="material-symbols-outlined ml-1">arrow_forward</span>
</div>
</div>
<!-- Social Growth -->
<div class="group bg-white p-8 rounded-[24px] border border-outline-variant/30 vibrant-shadow hover:translate-y-[-8px] transition-all duration-500">
<div class="w-16 h-16 rounded-2xl bg-tertiary-container/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
<span class="material-symbols-outlined text-tertiary text-4xl" data-icon="hub">hub</span>
</div>
<h3 class="font-cs-headline-md text-cs-headline-md mb-4 text-on-surface">Social Growth</h3>
<p class="text-on-surface-variant mb-6 leading-relaxed">Hyper-saturated visual campaigns designed to dominate feeds and foster high-octane community engagement.</p>
<div class="flex items-center text-tertiary font-bold group-hover:gap-2 transition-all">
                            Explore <span class="material-symbols-outlined ml-1">arrow_forward</span>
</div>
</div>
<!-- Conversion UX -->
<div class="group bg-white p-8 rounded-[24px] border border-outline-variant/30 vibrant-shadow hover:translate-y-[-8px] transition-all duration-500">
<div class="w-16 h-16 rounded-2xl bg-on-primary-fixed-variant/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
<span class="material-symbols-outlined text-primary-container text-4xl" data-icon="ads_click">ads_click</span>
</div>
<h3 class="font-cs-headline-md text-cs-headline-md mb-4 text-on-surface">Conversion UX</h3>
<p class="text-on-surface-variant mb-6 leading-relaxed">Psychology-backed interfaces optimized for conversion focus without sacrificing your creative flair.</p>
<div class="flex items-center text-primary-container font-bold group-hover:gap-2 transition-all">
                            Explore <span class="material-symbols-outlined ml-1">arrow_forward</span>
</div>
</div>
</div>
</div>
</section>
<!-- The Process Section -->
<section class="py-32 bg-on-background text-white relative overflow-hidden">
<div class="absolute top-0 right-0 w-1/2 h-full opacity-10">

</div>
<div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop relative z-10">
<div class="text-center mb-20">
<h2 class="font-cs-headline-lg text-cs-headline-lg-mobile md:text-cs-headline-lg mb-4">Our High-Octane Flow</h2>
<div class="flex items-center justify-center gap-2">
<div class="w-2 h-2 bg-primary rounded-sm"></div>
<div class="w-2 h-2 bg-secondary rounded-sm"></div>
<div class="w-2 h-2 bg-tertiary-fixed-dim rounded-sm"></div>
</div>
</div>
<div class="flex flex-col md:flex-row justify-between items-start gap-12 relative">
<!-- Connection Line (Desktop) -->
<div class="hidden md:block absolute top-12 left-0 w-full h-[2px] bg-gradient-to-r from-primary via-secondary to-tertiary opacity-30"></div>
<!-- Step 1 -->
<div class="flex-1 relative">
<div class="w-24 h-24 rounded-full border-4 border-primary bg-on-background flex items-center justify-center mb-8 relative z-10 mx-auto md:mx-0">
<span class="font-cs-display-lg text-cs-headline-lg text-primary">01</span>
</div>
<h3 class="font-cs-headline-md text-cs-headline-md mb-4 text-center md:text-left">Ideate</h3>
<p class="text-surface-dim/70 leading-relaxed text-center md:text-left">Deep-dive discovery to map your goals and ignite the conceptual creative spark.</p>
</div>
<!-- Step 2 -->
<div class="flex-1 relative">
<div class="w-24 h-24 rounded-full border-4 border-secondary bg-on-background flex items-center justify-center mb-8 relative z-10 mx-auto md:mx-0">
<span class="font-cs-display-lg text-cs-headline-lg text-secondary">02</span>
</div>
<h3 class="font-cs-headline-md text-cs-headline-md mb-4 text-center md:text-left">Ignite</h3>
<p class="text-surface-dim/70 leading-relaxed text-center md:text-left">Rapid execution where vision meets craft. We build the engine that powers your brand.</p>
</div>
<!-- Step 3 -->
<div class="flex-1 relative">
<div class="w-24 h-24 rounded-full border-4 border-tertiary-fixed-dim bg-on-background flex items-center justify-center mb-8 relative z-10 mx-auto md:mx-0">
<span class="font-cs-display-lg text-cs-headline-lg text-tertiary-fixed-dim">03</span>
</div>
<h3 class="font-cs-headline-md text-cs-headline-md mb-4 text-center md:text-left">Impact</h3>
<p class="text-surface-dim/70 leading-relaxed text-center md:text-left">Launch and optimization. Measurable success that establishes your professional confidence.</p>
</div>
</div>
</div>
</section>
<!-- FAQ Section -->
<section class="py-24 bg-surface">
<div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
<div>
<h2 class="font-cs-display-lg text-cs-headline-lg mb-6 leading-tight">Frequently Asked Questions</h2>
<p class="text-on-surface-variant font-cs-body-lg mb-10">We believe in radical transparency. Here are some quick answers to how we work.</p>
<div class="space-y-4">
<!-- Accordion Item 1 -->
<div class="accordion-item bg-white rounded-xl border border-outline-variant/30 vibrant-shadow overflow-hidden group cursor-pointer" onclick="this.classList.toggle('active')">
<div class="p-6 flex justify-between items-center">
<span class="font-cs-headline-md text-[18px]">What is the typical project timeline?</span>
<span class="material-symbols-outlined icon-rotate transition-transform duration-300">expand_more</span>
</div>
<div class="accordion-content">
<div class="px-6 pb-6 text-on-surface-variant">
                                    Most full-suite projects span 4-8 weeks, depending on complexity. We prioritize quality over speed while maintaining a kinetic momentum.
                                </div>
</div>
</div>
<!-- Accordion Item 2 -->
<div class="accordion-item bg-white rounded-xl border border-outline-variant/30 vibrant-shadow overflow-hidden group cursor-pointer" onclick="this.classList.toggle('active')">
<div class="p-6 flex justify-between items-center">
<span class="font-cs-headline-md text-[18px]">Do you offer ongoing support?</span>
<span class="material-symbols-outlined icon-rotate transition-transform duration-300">expand_more</span>
</div>
<div class="accordion-content">
<div class="px-6 pb-6 text-on-surface-variant">
                                    Absolutely. We provide flexible retainer options for "Social Growth" and "Conversion UX" to ensure your brand stays high-octane.
                                </div>
</div>
</div>
<!-- Accordion Item 3 -->
<div class="accordion-item bg-white rounded-xl border border-outline-variant/30 vibrant-shadow overflow-hidden group cursor-pointer" onclick="this.classList.toggle('active')">
<div class="p-6 flex justify-between items-center">
<span class="font-cs-headline-md text-[18px]">Can we start with just one service?</span>
<span class="material-symbols-outlined icon-rotate transition-transform duration-300">expand_more</span>
</div>
<div class="accordion-content">
<div class="px-6 pb-6 text-on-surface-variant">
                                    Yes, though we find the best results come from our holistic integration, we are happy to start with a focused "toolkit" approach.
                                </div>
</div>
</div>
</div>
</div>
<div class="relative hidden lg:block">
<div class="absolute -inset-4 bg-gradient-to-tr from-primary/20 to-secondary/20 rounded-[40px] blur-2xl"></div>
<img class="relative z-10 w-full h-[500px] object-cover rounded-[40px] vibrant-shadow border border-white" data-alt="A futuristic and abstract digital visualization of 3D crystal geometric shapes floating in a clean, minimalist white studio. Soft purple and pink ambient lighting reflects off polished surfaces, creating a high-end, gallery-like atmosphere. The composition is asymmetrical and modern, representing the intersection of creative ideas and technical precision." src="https://lh3.googleusercontent.com/aida-public/AB6AXuD6iD_4L1MTgrLHZRtcxEaQvOdtRn5e6ZBeKdGNGEvoYJiec1USpCPl6qVAxXcTFXM5wSHdqjUXsXh3Ltb3kqxX9FYOK6T3QUjCEcD3hOorfo9RuzyMt7rCOhseXer3_VL4BXdsZIHS86UCpymE_AHaVqrCQ86tyn9WIE5CrfI35DAefQKlPxjVrJqNIH_s0sc3fHrfiH4InzUUCSEwZcin3lG8PjBoHgxro6I9YDhWiD4lXtBYgosTUxRiLNPu22yf6nhC2n92-oeF"/>
</div>
</div>
</section>
<!-- CTA Section -->
<section class="py-24 max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
<div class="gradient-btn rounded-[40px] p-12 md:p-20 text-center text-white relative overflow-hidden shadow-2xl">
<div class="absolute inset-0 opacity-20 pointer-events-none">
<div class="absolute top-0 left-0 w-64 h-64 bg-white/20 blur-[100px] rounded-full"></div>
<div class="absolute bottom-0 right-0 w-96 h-96 bg-black/20 blur-[100px] rounded-full"></div>
</div>
<h2 class="font-cs-display-lg text-cs-headline-lg-mobile md:text-cs-headline-lg mb-8 relative z-10">Ready to ignite your next big idea?</h2>
<div class="flex flex-col md:flex-row gap-6 justify-center items-center relative z-10">
<button class="bg-white text-primary px-10 py-4 rounded-full font-bold text-lg hover:scale-105 transition-all">Start My Project</button>
<button class="border-2 border-white/50 text-white px-10 py-4 rounded-full font-bold text-lg hover:bg-white/10 transition-all">View Our Work</button>
</div>
</div>
</section>
</main>

</TemplateLayout>
