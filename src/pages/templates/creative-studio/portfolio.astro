---
import TemplateLayout from "@/templates/creative-studio/TemplateLayout.astro";
---

<TemplateLayout
  title="Portfolio | The Creative Collective"
  description="Selected work from The Creative Collective — brand identity, campaigns, and digital experiences."
  active="portfolio"
  canonicalPath="/templates/creative-studio/portfolio"
>
<!-- Hero Section -->
<header class="relative overflow-hidden pt-20 pb-32">
<div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop relative z-10 text-center">
<div class="inline-block px-4 py-1.5 mb-6 rounded-full bg-secondary-fixed text-on-secondary-fixed font-cs-label-md text-cs-label-md">
                CURATED WORKS 2024
            </div>
<h1 class="font-cs-display-lg text-cs-display-lg-mobile md:text-cs-display-lg mb-8 leading-tight">
                The <span class="gradient-text">Hall of Spark.</span>
</h1>
<p class="font-cs-body-lg text-cs-body-lg text-on-surface-variant max-w-2xl mx-auto">
                A sanctuary where bold ideas meet kinetic execution. We don't just design; we ignite digital revolutions for creators who demand the extraordinary.
            </p>
</div>
<!-- Subtle Animated BG -->
<div class="absolute inset-0 -z-10 opacity-20">

</div>
</header>
<!-- Filter Section -->
<section class="mb-16">
<div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
<div class="flex flex-wrap justify-center gap-4 md:gap-8">
<button class="filter-btn active px-8 py-3 rounded-full font-cs-label-md text-cs-label-md transition-all duration-300 border-2 border-transparent bg-secondary text-white shadow-md" onclick="filterProjects('all')">All</button>
<button class="filter-btn px-8 py-3 rounded-full font-cs-label-md text-cs-label-md transition-all duration-300 border-2 border-outline-variant hover:border-secondary hover:text-secondary" onclick="filterProjects('brand')">Brand</button>
<button class="filter-btn px-8 py-3 rounded-full font-cs-label-md text-cs-label-md transition-all duration-300 border-2 border-outline-variant hover:border-secondary hover:text-secondary" onclick="filterProjects('web')">Web</button>
<button class="filter-btn px-8 py-3 rounded-full font-cs-label-md text-cs-label-md transition-all duration-300 border-2 border-outline-variant hover:border-secondary hover:text-secondary" onclick="filterProjects('motion')">Motion</button>
</div>
</div>
</section>
<!-- Project Grid -->
<main class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop pb-32">
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter" id="project-grid">
<!-- Project Card 1 -->
<div class="project-card group relative overflow-hidden rounded-[24px] bg-white border border-outline-variant/30 shadow-[0px_10px_30px_rgba(121,40,202,0.05)] transition-all duration-500 hover:-translate-y-2 hover:shadow-[0px_20px_40px_rgba(121,40,202,0.12)]" data-category="brand">
<div class="aspect-[4/5] overflow-hidden">
<img class="w-full h-full object-cover transition-transform duration-700" data-alt="A striking minimalist branding project showcase featuring bold typography and hyper-saturated pink accents against a clean white gallery background. The aesthetic is modern and high-contrast, designed to look like a premium studio portfolio piece. High-end product photography of business cards and stationery." src="https://lh3.googleusercontent.com/aida-public/AB6AXuDCmvbHC5aAxbrl7sSwKgEgWtxVps3L7-TwxacIl4c2oOQGjWzOZgHWsFrQj4LZ410MJs_Ye6LBcVYogpm87ZOvRJZsXMTN7k9d-XMafh6qrZBixIr0gkypKA0wTk2H9kMVdu2gbIYaigKl3FuLwMZmFwGR-be6jlnGzFdvlWkSo642QGrz4f40vcQL-q54NgD3AA96szoJ__pfGe8okHpdGPgn67mcpkxIXwlU_Je74_gOaZvOEa3uEfsplyk24geAoS-q8zchu72n"/>
</div>
<div class="project-overlay absolute inset-0 bg-gradient-to-t from-secondary/90 via-secondary/20 to-transparent opacity-0 transition-opacity duration-300 flex flex-col justify-end p-8">
<span class="text-white/80 font-cs-label-md text-cs-label-md mb-2">IDENTITY</span>
<h3 class="text-white font-cs-headline-md text-cs-headline-md leading-tight mb-4">Aura Cosmetics</h3>
<button class="bg-white text-secondary font-bold py-3 px-6 rounded-full self-start hover:scale-105 transition-transform">View Project</button>
</div>
</div>
<!-- Project Card 2 -->
<div class="project-card group relative overflow-hidden rounded-[24px] bg-white border border-outline-variant/30 shadow-[0px_10px_30px_rgba(121,40,202,0.05)] transition-all duration-500 hover:-translate-y-2 hover:shadow-[0px_20px_40px_rgba(121,40,202,0.12)]" data-category="web">
<div class="aspect-[4/5] overflow-hidden">
<img class="w-full h-full object-cover transition-transform duration-700" data-alt="A sleek, futuristic website design mockup displayed on a modern monitor. The layout features glassmorphism elements, vibrant purple glowing effects, and asymmetrical grid structures. The color palette is clean with splashes of electric cyan and deep magenta. Professional digital interface design." src="https://lh3.googleusercontent.com/aida-public/AB6AXuBQRHuklHx1SbpLn34xxUyeSAns-BTOdimV1p78Go7nYxGgD9W2JsJAl_zqydoJ4XhoSAg9DOw18PqB9vc8xMXS66_Ftb0EYUcUsZB9YbOgJ4Lj7e6Oe7U0vnJ3-xf-Xv4NeAm3MQMVjqOlPL5ENqbhFXabiiKEJVK64lunBtPt8v1z_tOcIvkQy4ivowfz0D5PmhPNI7fKB4G63QHqlwQMSiEewnB4NHsVXvcG5vl4UQtdPwbb_dbB_gdeGsfz77CcX-ljtkggwjMp"/>
</div>
<div class="project-overlay absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/20 to-transparent opacity-0 transition-opacity duration-300 flex flex-col justify-end p-8">
<span class="text-white/80 font-cs-label-md text-cs-label-md mb-2">INTERFACE</span>
<h3 class="text-white font-cs-headline-md text-cs-headline-md leading-tight mb-4">Zenith Fintech</h3>
<button class="bg-white text-primary font-bold py-3 px-6 rounded-full self-start hover:scale-105 transition-transform">View Project</button>
</div>
</div>
<!-- Project Card 3 -->
<div class="project-card group relative overflow-hidden rounded-[24px] bg-white border border-outline-variant/30 shadow-[0px_10px_30px_rgba(121,40,202,0.05)] transition-all duration-500 hover:-translate-y-2 hover:shadow-[0px_20px_40px_rgba(121,40,202,0.12)]" data-category="motion">
<div class="aspect-[4/5] overflow-hidden">
<img class="w-full h-full object-cover transition-transform duration-700" data-alt="A dynamic motion graphics still showing explosive geometric shapes in vibrant purple and pink. The lighting is dramatic and high-contrast, creating a sense of kinetic energy and professional creative flair. The composition uses a minimalist background to emphasize the bold colorful motion." src="https://lh3.googleusercontent.com/aida-public/AB6AXuAh94fmtgXneXxkPFFuzoWLpRm9aZD-L_yed5Qyi5L_msGr8vx7HZO9L9GfsoUY1Nkx-is9TV_2RVl39gATzPaCvjQjvwBDusBBq-RLDk1QiKZa7yGEE7k9wGDtRjXU1UXyfwd0nqyneO7bCSY1_vD1NRkqlye8zJlkJ4H15BmmwIIiYUBdJZGdLV8mt1OcL52gAVdv9yDCw72_95Pjvr5BRqbC5PrkLkM90YLNt9G8VOXJU8imFMhG971mxVstN6txvUf8ieE7SG06"/>
</div>
<div class="project-overlay absolute inset-0 bg-gradient-to-t from-on-secondary-fixed-variant/90 via-on-secondary-fixed-variant/20 to-transparent opacity-0 transition-opacity duration-300 flex flex-col justify-end p-8">
<span class="text-white/80 font-cs-label-md text-cs-label-md mb-2">KINETIC</span>
<h3 class="text-white font-cs-headline-md text-cs-headline-md leading-tight mb-4">Pulse 2024</h3>
<button class="bg-white text-secondary font-bold py-3 px-6 rounded-full self-start hover:scale-105 transition-transform">View Project</button>
</div>
</div>
<!-- Project Card 4 -->
<div class="project-card group relative overflow-hidden rounded-[24px] bg-white border border-outline-variant/30 shadow-[0px_10px_30px_rgba(121,40,202,0.05)] transition-all duration-500 hover:-translate-y-2 hover:shadow-[0px_20px_40px_rgba(121,40,202,0.12)]" data-category="web">
<div class="aspect-[4/5] overflow-hidden">
<img class="w-full h-full object-cover transition-transform duration-700" data-alt="Modern high-end e-commerce mobile app screens with minimalist aesthetic. The UI uses white space aggressively with sharp typography and soft purple shadows. Beautiful product photography integrated into a clean digital layout." src="https://lh3.googleusercontent.com/aida-public/AB6AXuBxQxNcgEpK6q-oz_R3uc77Qr768ZDFXZSH5PbmT-5dEe8zVvzgOk3iEE03icbN7KI0GCiQ5Jje2-r-IVILW-6kKH8TVNz1GGpWr8F7c-ym2HUuPIMHUqIb51YQQc4Y71oxPkDSllEYx2GjAIhxzVPaKLGkkTXh_i9HnbWVgTGWTamrttBOcyGbzLYSwEyHiGX7_18xVSMaOi9GductYiDGvfuAzfXYgRalgWCZTo811Yse24tIa8PLRzJYCvCRL1ZHQhWSxpjIr7_j"/>
</div>
<div class="project-overlay absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/20 to-transparent opacity-0 transition-opacity duration-300 flex flex-col justify-end p-8">
<span class="text-white/80 font-cs-label-md text-cs-label-md mb-2">ECOMMERCE</span>
<h3 class="text-white font-cs-headline-md text-cs-headline-md leading-tight mb-4">Sole Society</h3>
<button class="bg-white text-primary font-bold py-3 px-6 rounded-full self-start hover:scale-105 transition-transform">View Project</button>
</div>
</div>
<!-- Project Card 5 -->
<div class="project-card group relative overflow-hidden rounded-[24px] bg-white border border-outline-variant/30 shadow-[0px_10px_30px_rgba(121,40,202,0.05)] transition-all duration-500 hover:-translate-y-2 hover:shadow-[0px_20px_40px_rgba(121,40,202,0.12)]" data-category="brand">
<div class="aspect-[4/5] overflow-hidden">
<img class="w-full h-full object-cover transition-transform duration-700" data-alt="A bold logo design and visual identity reveal for a creative agency. The graphics are sharp and geometric, using a palette of deep pink and royal purple. Mockups include outdoor billboards and high-quality studio interiors." src="https://lh3.googleusercontent.com/aida-public/AB6AXuC3WZdPOUB1qsA9J07pIsp-46ZukLKDLcJwGQA27zYiUec5n8svDdWEikHpMdHkm6oaFGxUJk5wjbDEQWcHhaw3srqQKfW_99IMii_5Qp1IK5d8xNE67OjmMr59qr6Zq9K75yBBqcu7oIizSvAhQfdcitNR2Po6tHfBu5fgRowey4umYSuYU7VdQtr8fcRKViJqGO-niB_6w9u7O9_FU1BYKnnMoArlzgUIXITWNn6egG2KTArX1OlXumyWODroHK1jSmBkg7s_WqSx"/>
</div>
<div class="project-overlay absolute inset-0 bg-gradient-to-t from-secondary/90 via-secondary/20 to-transparent opacity-0 transition-opacity duration-300 flex flex-col justify-end p-8">
<span class="text-white/80 font-cs-label-md text-cs-label-md mb-2">REBRAND</span>
<h3 class="text-white font-cs-headline-md text-cs-headline-md leading-tight mb-4">Prism Collective</h3>
<button class="bg-white text-secondary font-bold py-3 px-6 rounded-full self-start hover:scale-105 transition-transform">View Project</button>
</div>
</div>
<!-- Project Card 6 -->
<div class="project-card group relative overflow-hidden rounded-[24px] bg-white border border-outline-variant/30 shadow-[0px_10px_30px_rgba(121,40,202,0.05)] transition-all duration-500 hover:-translate-y-2 hover:shadow-[0px_20px_40px_rgba(121,40,202,0.12)]" data-category="motion">
<div class="aspect-[4/5] overflow-hidden">
<img class="w-full h-full object-cover transition-transform duration-700" data-alt="A still frame from an abstract 3D animation featuring liquid metal textures glowing in magenta and cyan light. The visual is cinematic and professional, showcasing high-level creative execution for a tech brand's introduction video." src="https://lh3.googleusercontent.com/aida-public/AB6AXuAKpt7QFeqfgZfUWzTTxVZ1QsBg5bKeRpnO4rvYeLPys3C2u1kw4AHcNaE5NeHuUSZ3YcaEcvqsYTzYTS5iE95TlQr7pFD63oxBH-2NJEXy-L-LLp3FjgL4W5NH_SWJXVLENwQVdEIERCud-fndZ0HOfAelp_xI4DVU2iNn3_cVaqdDwSB0csTGJkCNVObGav-KZ9WNcd2m0BG2AcUzk1_VZoaYUPDINiB2faU04x6Qyd2PSszS672wOrcKOVlRkmXRqotGoWFOscvZ"/>
</div>
<div class="project-overlay absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/20 to-transparent opacity-0 transition-opacity duration-300 flex flex-col justify-end p-8">
<span class="text-white/80 font-cs-label-md text-cs-label-md mb-2">PRODUCTION</span>
<h3 class="text-white font-cs-headline-md text-cs-headline-md leading-tight mb-4">Hyperloop Labs</h3>
<button class="bg-white text-primary font-bold py-3 px-6 rounded-full self-start hover:scale-105 transition-transform">View Project</button>
</div>
</div>
</div>
</main>
<!-- Testimonials Section -->
<section class="bg-surface-container-low py-32 overflow-hidden relative">
<div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop relative z-10">
<div class="flex flex-col items-center text-center">
<div class="mb-8">
<span class="material-symbols-outlined text-6xl text-primary/30" style="font-variation-settings: 'FILL' 1;">format_quote</span>
</div>
<h2 class="font-cs-headline-lg text-cs-headline-lg-mobile md:text-cs-headline-lg mb-12 max-w-4xl italic">
                    "They didn't just build a site; they built our <span class="gradient-text">future</span>."
                </h2>
<div class="flex items-center gap-4">
<div class="w-16 h-16 rounded-full overflow-hidden border-2 border-secondary shadow-lg">
<img class="w-full h-full object-cover" data-alt="Professional headshot of a female tech CEO in a minimalist office setting. She has a confident, visionary expression. The lighting is soft and bright, matching a light-mode creative studio aesthetic." src="https://lh3.googleusercontent.com/aida-public/AB6AXuAPu-7HJWgPy-GVetYUkzEGClUoCjksQPMSCF0eraZbX7mmcpy8Bztv8qXXLsSxdAzqGLt_BUOsfGgUM8daTP6egxcK4bP4vMQl6zJqCUn2mITlJYNBkZn7EMXCeW0-qf2p04iWDYUAXEV6A0skcxFKcvRWwz30GRMRo0RvPG0Or6Mb12AaM_lyuab6WID_Xit5EFh12m5IpfqJmBRxcqOUEZkt_aPjNu8a81EYooc_0yqXCxAsrC42vUqtaVTifX_s4l9ueX_RKzRE"/>
</div>
<div class="text-left">
<p class="font-bold text-on-surface font-cs-body-lg">Alexandra Chen</p>
<p class="text-on-surface-variant font-cs-body-md">Founder, Zenith Digital</p>
</div>
</div>
</div>
</div>
<!-- Decorative Geometric Form -->
<div class="absolute -right-20 -top-20 w-80 h-80 rounded-full bg-primary/5 blur-3xl"></div>
<div class="absolute -left-20 -bottom-20 w-80 h-80 rounded-full bg-secondary/5 blur-3xl"></div>
</section>
<!-- CTA Section -->
<section class="py-32">
<div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop text-center">
<h2 class="font-cs-display-lg text-cs-headline-lg-mobile md:text-cs-headline-lg mb-8">Ready to spark?</h2>
<p class="font-cs-body-lg text-cs-body-lg text-on-surface-variant mb-12 max-w-xl mx-auto">
                Join the collective of forward-thinking brands that choose bold aesthetic and functional excellence.
            </p>
<div class="flex flex-wrap justify-center gap-6">
<button class="bg-gradient-to-r from-primary to-secondary text-white font-bold py-5 px-12 rounded-full hover:scale-105 active:scale-95 transition-all shadow-xl font-cs-headline-md">
                    Launch Your Project
                </button>
<button class="border-2 border-primary text-primary font-bold py-5 px-12 rounded-full hover:bg-primary/5 active:scale-95 transition-all font-cs-headline-md">
                    Our Services
                </button>
</div>
</div>
</section>

</TemplateLayout>
