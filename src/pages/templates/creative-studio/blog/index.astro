---
import TemplateLayout from "@/templates/creative-studio/TemplateLayout.astro";
import { blogPosts } from "@/lib/blog";

const posts = blogPosts["creative-studio"];
---

<TemplateLayout
  title="Journal | The Creative Collective"
  description="Notes on branding, web design, and motion from The Creative Collective's studio team."
  active="blog"
  canonicalPath="/templates/creative-studio/blog"
>
<main class="overflow-x-hidden">
<section class="pt-24 pb-16 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
<span class="inline-block px-4 py-1 rounded-full bg-secondary-fixed text-on-secondary-fixed font-cs-label-md text-cs-label-md mb-6 uppercase tracking-widest">The Journal</span>
<h1 class="font-cs-display-lg text-cs-display-lg-mobile md:text-cs-display-lg text-on-surface mb-6 max-w-2xl">Notes on brand, design &amp; motion.</h1>
<p class="font-cs-body-lg text-cs-body-lg text-on-surface-variant max-w-lg">Field notes from our studio team on what's actually working in branding, web design, and motion right now.</p>
</section>
<section class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto pb-24">
<div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
{posts.map((post) => (
<a href={`/templates/creative-studio/blog/${post.slug}`} class="group bg-surface-container-lowest p-8 rounded-[24px] border border-outline-variant/30 vibrant-shadow flex flex-col">
<span class="font-cs-label-md text-cs-label-md text-secondary uppercase tracking-widest mb-4 block">{post.category}</span>
<h2 class="font-cs-headline-md text-cs-headline-md mb-4 group-hover:text-primary transition-colors">{post.title}</h2>
<p class="font-cs-body-md text-cs-body-md text-on-surface-variant mb-6 flex-grow">{post.excerpt}</p>
<div class="flex items-center justify-between font-cs-label-md text-cs-label-md text-on-surface-variant uppercase tracking-widest pt-4 border-t border-outline-variant/20">
<span>{post.date}</span>
<span>{post.readTime}</span>
</div>
</a>
))}
</div>
</section>
</main>
</TemplateLayout>
