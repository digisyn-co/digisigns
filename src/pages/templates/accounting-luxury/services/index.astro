---
import TemplateLayout from "@/templates/accounting-luxury/TemplateLayout.astro";
---

<TemplateLayout
  title="Services | Estate & Accord"
  description="Private wealth, estate and multi-generational planning, and institutional audit — the core advisory capabilities of Estate & Accord."
  active="services"
  canonicalPath="/templates/accounting-luxury/services"
>
<!-- Hero Section -->
<header class="px-margin-desktop max-w-ea-container-max mx-auto mb-stack-lg">
<div class="grid grid-cols-1 md:grid-cols-12 gap-gutter items-end">
<div class="md:col-span-8">
<span class="font-ea-label-sm text-ea-label-sm uppercase tracking-widest text-secondary mb-4 block">Strategic Architecture</span>
<h1 class="font-display-lg text-display-lg mb-6 leading-tight">
                        Precision-Engineered <br/>
<span class="italic font-normal">Wealth Governance.</span>
</h1>
<p class="font-body-lg text-body-lg text-on-surface-variant max-w-xl">
                        A suite of bespoke financial instruments and advisory services designed for the meticulous preservation of institutional and private capital.
                    </p>
</div>
<div class="md:col-span-4 flex justify-end">
<div class="text-right">
<div class="font-ea-label-sm text-ea-label-sm uppercase tracking-tighter text-on-surface-variant opacity-50 mb-2">Global Assets Under Management</div>
<div class="font-ea-headline-md text-ea-headline-md">$14.2B+</div>
</div>
</div>
</div>
</header>
<!-- Service Categories - Bento Grid -->
<section class="px-margin-desktop max-w-ea-container-max mx-auto mb-stack-lg">
<div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
<a href="/templates/accounting-luxury/contact" class="bg-surface-container-lowest p-10 deep-shadow floating-card transition-all duration-500 group flex flex-col justify-between min-h-[420px]">
<div>
<div class="text-secondary mb-8">
<span class="material-symbols-outlined !text-4xl">account_balance_wallet</span>
</div>
<h3 class="font-headline-sm text-headline-sm mb-4">Private Wealth</h3>
<p class="font-body-md text-body-md text-on-surface-variant">
                            Intergenerational wealth preservation strategies, including family office structures, liquid asset management, and concierge fiduciary services.
                        </p>
</div>
<div class="mt-8">
<ul class="space-y-3 mb-8">
<li class="flex items-center font-ea-label-sm text-ea-label-sm uppercase tracking-widest text-on-surface-variant">
<span class="material-symbols-outlined text-secondary mr-2 !text-lg">check_small</span>
                                Estate Planning
                            </li>
<li class="flex items-center font-ea-label-sm text-ea-label-sm uppercase tracking-widest text-on-surface-variant">
<span class="material-symbols-outlined text-secondary mr-2 !text-lg">check_small</span>
                                Legacy Governance
                            </li>
</ul>
<span class="font-label-md text-label-md uppercase tracking-widest gold-underline inline-block">Explore Strategy</span>
</div>
</a>
<a href="/templates/accounting-luxury/services/estate-multigenerational-planning" class="bg-primary-container text-on-primary p-10 deep-shadow floating-card transition-all duration-500 flex flex-col justify-between min-h-[420px]">
<div>
<div class="text-secondary-fixed mb-8">
<span class="material-symbols-outlined !text-4xl">monitoring</span>
</div>
<h3 class="font-headline-sm text-headline-sm mb-4 text-surface">Tax Strategy</h3>
<p class="font-body-md text-body-md text-primary-fixed-dim">
                            Advanced multi-jurisdictional tax optimization and regulatory compliance designed for complex global financial footprints.
                        </p>
</div>
<div class="mt-8">
<ul class="space-y-3 mb-8">
<li class="flex items-center font-ea-label-sm text-ea-label-sm uppercase tracking-widest text-primary-fixed-dim">
<span class="material-symbols-outlined text-secondary-fixed mr-2 !text-lg">check_small</span>
                                Global Compliance
                            </li>
<li class="flex items-center font-ea-label-sm text-ea-label-sm uppercase tracking-widest text-primary-fixed-dim">
<span class="material-symbols-outlined text-secondary-fixed mr-2 !text-lg">check_small</span>
                                Asset Shielding
                            </li>
</ul>
<span class="font-label-md text-label-md uppercase tracking-widest text-secondary-fixed inline-block hover:brightness-110 transition-all">View Estate &amp; Multi-Generational Planning</span>
</div>
</a>
<a href="/templates/accounting-luxury/contact" class="bg-surface-container-lowest p-10 deep-shadow floating-card transition-all duration-500 flex flex-col justify-between min-h-[420px]">
<div>
<div class="text-secondary mb-8">
<span class="material-symbols-outlined !text-4xl">verified_user</span>
</div>
<h3 class="font-headline-sm text-headline-sm mb-4">Institutional Audit</h3>
<p class="font-body-md text-body-md text-on-surface-variant">
                            Meticulous financial oversight and independent auditing for corporate entities, non-profits, and sovereign wealth foundations.
                        </p>
</div>
<div class="mt-8">
<ul class="space-y-3 mb-8">
<li class="flex items-center font-ea-label-sm text-ea-label-sm uppercase tracking-widest text-on-surface-variant">
<span class="material-symbols-outlined text-secondary mr-2 !text-lg">check_small</span>
                                Forensic Analysis
                            </li>
<li class="flex items-center font-ea-label-sm text-ea-label-sm uppercase tracking-widest text-on-surface-variant">
<span class="material-symbols-outlined text-secondary mr-2 !text-lg">check_small</span>
                                Risk Mitigation
                            </li>
</ul>
<span class="font-label-md text-label-md uppercase tracking-widest gold-underline inline-block">Review Framework</span>
</div>
</a>
</div>
</section>
<!-- Service Tiers / Comparison -->
<section class="bg-surface-container py-stack-lg">
<div class="px-margin-desktop max-w-ea-container-max mx-auto">
<div class="mb-16 text-center">
<h2 class="font-ea-headline-md text-ea-headline-md mb-4">Select Your Mandate</h2>
<p class="font-body-md text-body-md text-on-surface-variant max-w-2xl mx-auto">
                        Tiered levels of engagement tailored to your specific complexity and reporting requirements.
                    </p>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
<div class="bg-white p-8 flex flex-col h-full border-t-2 border-transparent">
<div class="mb-8">
<h4 class="font-label-md text-label-md uppercase tracking-widest mb-2">Essential</h4>
<div class="flex items-baseline mb-4">
<span class="font-headline-sm text-headline-sm">$5k</span>
<span class="font-ea-label-sm text-ea-label-sm text-on-surface-variant ml-2">/ QUARTER</span>
</div>
<p class="font-body-md text-body-md text-on-surface-variant text-sm">Focused wealth management for emerging portfolios.</p>
</div>
<div class="flex-grow space-y-4 mb-12">
<div class="flex justify-between items-center razor-border-bottom pb-2">
<span class="font-ea-label-sm text-ea-label-sm uppercase text-on-surface-variant">Direct Advisory</span>
<span class="material-symbols-outlined text-secondary">check</span>
</div>
<div class="flex justify-between items-center razor-border-bottom pb-2">
<span class="font-ea-label-sm text-ea-label-sm uppercase text-on-surface-variant">Tax Prep</span>
<span class="material-symbols-outlined text-secondary">check</span>
</div>
<div class="flex justify-between items-center razor-border-bottom pb-2">
<span class="font-ea-label-sm text-ea-label-sm uppercase text-on-surface-variant">Global Access</span>
<span class="material-symbols-outlined text-outline/30">close</span>
</div>
</div>
<a href="/templates/accounting-luxury/contact" class="w-full block text-center border border-primary py-4 font-label-md text-label-md uppercase tracking-widest hover:bg-primary hover:text-on-primary transition-all">Initiate Engagement</a>
</div>
<div class="bg-white p-8 flex flex-col h-full relative deep-shadow transform md:scale-105 z-10 border-t-2 border-secondary">
<div class="absolute top-0 right-8 transform -translate-y-1/2 bg-secondary text-on-secondary px-4 py-1 font-ea-label-sm text-ea-label-sm uppercase tracking-widest">Most Requested</div>
<div class="mb-8">
<h4 class="font-label-md text-label-md uppercase tracking-widest mb-2">Accord Signature</h4>
<div class="flex items-baseline mb-4">
<span class="font-headline-sm text-headline-sm">$15k</span>
<span class="font-ea-label-sm text-ea-label-sm text-on-surface-variant ml-2">/ QUARTER</span>
</div>
<p class="font-body-md text-body-md text-on-surface-variant text-sm">Full-spectrum management for high-complexity individuals.</p>
</div>
<div class="flex-grow space-y-4 mb-12">
<div class="flex justify-between items-center razor-border-bottom pb-2">
<span class="font-ea-label-sm text-ea-label-sm uppercase text-on-surface-variant">24/7 Concierge</span>
<span class="material-symbols-outlined text-secondary">check</span>
</div>
<div class="flex justify-between items-center razor-border-bottom pb-2">
<span class="font-ea-label-sm text-ea-label-sm uppercase text-on-surface-variant">Global Tax Optimization</span>
<span class="material-symbols-outlined text-secondary">check</span>
</div>
<div class="flex justify-between items-center razor-border-bottom pb-2">
<span class="font-ea-label-sm text-ea-label-sm uppercase text-on-surface-variant">Trust Services</span>
<span class="material-symbols-outlined text-secondary">check</span>
</div>
</div>
<a href="/templates/accounting-luxury/contact" class="w-full block text-center bg-primary text-on-primary py-4 font-label-md text-label-md uppercase tracking-widest hover:bg-secondary transition-all shadow-lg">Initiate Engagement</a>
</div>
<div class="bg-white p-8 flex flex-col h-full border-t-2 border-transparent">
<div class="mb-8">
<h4 class="font-label-md text-label-md uppercase tracking-widest mb-2">Institutional</h4>
<div class="flex items-baseline mb-4">
<span class="font-headline-sm text-headline-sm">Bespoke</span>
</div>
<p class="font-body-md text-body-md text-on-surface-variant text-sm">Custom framework for corporations and foundations.</p>
</div>
<div class="flex-grow space-y-4 mb-12">
<div class="flex justify-between items-center razor-border-bottom pb-2">
<span class="font-ea-label-sm text-ea-label-sm uppercase text-on-surface-variant">On-Site Audits</span>
<span class="material-symbols-outlined text-secondary">check</span>
</div>
<div class="flex justify-between items-center razor-border-bottom pb-2">
<span class="font-ea-label-sm text-ea-label-sm uppercase text-on-surface-variant">Board Reporting</span>
<span class="material-symbols-outlined text-secondary">check</span>
</div>
<div class="flex justify-between items-center razor-border-bottom pb-2">
<span class="font-ea-label-sm text-ea-label-sm uppercase text-on-surface-variant">Compliance Shield</span>
<span class="material-symbols-outlined text-secondary">check</span>
</div>
</div>
<a href="/templates/accounting-luxury/contact" class="w-full block text-center border border-primary py-4 font-label-md text-label-md uppercase tracking-widest hover:bg-primary hover:text-on-primary transition-all">Consult Group</a>
</div>
</div>
</div>
</section>
<!-- Process Summary -->
<section class="px-margin-desktop max-w-ea-container-max mx-auto py-stack-lg">
<div class="grid grid-cols-1 md:grid-cols-12 gap-gutter items-center">
<div class="md:col-span-5">
<h2 class="font-ea-headline-md text-ea-headline-md mb-8">The Accord Methodology</h2>
<div class="space-y-12">
<div class="relative pl-12 border-l border-outline/20">
<div class="absolute -left-3 top-0 w-6 h-6 bg-secondary flex items-center justify-center text-on-secondary font-bold text-xs">01</div>
<h5 class="font-label-md text-label-md uppercase tracking-widest mb-2">Discovery &amp; Diagnostic</h5>
<p class="font-body-md text-body-md text-on-surface-variant">Exhaustive mapping of current assets, jurisdictional exposure, and long-term objectives.</p>
</div>
<div class="relative pl-12 border-l border-outline/20">
<div class="absolute -left-3 top-0 w-6 h-6 bg-primary flex items-center justify-center text-on-primary font-bold text-xs">02</div>
<h5 class="font-label-md text-label-md uppercase tracking-widest mb-2">Architectural Design</h5>
<p class="font-body-md text-body-md text-on-surface-variant">Creation of a bespoke financial structure prioritizing tax efficiency and risk shielding.</p>
</div>
<div class="relative pl-12 border-l border-outline/20">
<div class="absolute -left-3 top-0 w-6 h-6 bg-primary flex items-center justify-center text-on-primary font-bold text-xs">03</div>
<h5 class="font-label-md text-label-md uppercase tracking-widest mb-2">Continuous Governance</h5>
<p class="font-body-md text-body-md text-on-surface-variant">Ongoing oversight, real-time reporting, and strategic adjustments to market shifts.</p>
</div>
</div>
</div>
<div class="md:col-span-7">
<div class="aspect-video relative overflow-hidden group">
<div class="absolute inset-0 bg-primary/20 z-10"></div>
<div class="w-full h-full bg-cover bg-center transition-transform duration-1000 group-hover:scale-105" data-alt="A cinematic, high-contrast shot of a sleek, modern architectural building made of glass and steel, reflecting the setting sun. The image uses a minimalist luxury aesthetic with deep shadows and sharp lines, perfectly representing the precision and authority of an elite advisory group. The lighting is low-key and dramatic, creating a sense of exclusivity and quiet wealth." style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAjeqioQMM7PnwXzmIMyVqGFMgFIbzu0ZzwT8_oi8goNnRbg-_YCVZCyIIVvZD3cBXGrHExrZFIrnWeRJuVCbX-5yg79I_TiDA3kUDMnI-ySUMdOoskkHsIqMcJAuYw_HxD7u7wDRYwCyZss5awRcU51uhbsExhQPJNzIKnUxjpKl99vMKjUflKYShGrcAZojYcR-2a54K0cWS-PNGPt_f_ihdhNODtClG2HuRaJ5Z1oD5yx4EO4n5UBHXWxc_yiv6R-uE9uBrzj513')">
</div>
</div>
</div>
</div>
</section>
<!-- CTA Block -->
<section class="bg-primary py-stack-lg overflow-hidden relative">
<div class="px-margin-desktop max-w-ea-container-max mx-auto relative z-10 text-center">
<h2 class="font-display-lg text-display-lg text-surface mb-8">Secure Your Legacy Today.</h2>
<p class="font-body-lg text-body-lg text-primary-fixed-dim max-w-2xl mx-auto mb-12">
                    Our advisors are available for private consultations in our London, New York, and Singapore offices. Experience the Accord difference.
                </p>
<div class="flex flex-col md:flex-row justify-center items-center gap-6">
<a href="/templates/accounting-luxury/contact" class="bg-secondary text-on-secondary px-12 py-5 font-label-md text-label-md uppercase tracking-widest hover:bg-secondary-fixed-dim hover:text-on-secondary-fixed transition-all">Schedule Private Briefing</a>
<button class="border border-surface text-surface px-12 py-5 font-label-md text-label-md uppercase tracking-widest hover:bg-surface hover:text-primary transition-all">Download Prospectus</button>
</div>
</div>
</section>

</TemplateLayout>
