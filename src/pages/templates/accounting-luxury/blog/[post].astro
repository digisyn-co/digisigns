---
import TemplateLayout from "@/templates/accounting-luxury/TemplateLayout.astro";
import { blogPosts } from "@/lib/blog";

export function getStaticPaths() {
  return blogPosts["accounting-luxury"].map((post) => ({
    params: { post: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const related = blogPosts["accounting-luxury"].filter((p) => p.slug !== post.slug).slice(0, 2);
---

<TemplateLayout
  title={`${post.title} | Estate & Accord`}
  description={post.excerpt}
  active="blog"
  canonicalPath={`/templates/accounting-luxury/blog/${post.slug}`}
>
<div class="max-w-3xl mx-auto px-margin-desktop">
<a href="/templates/accounting-luxury/blog" class="font-ea-label-sm text-ea-label-sm uppercase tracking-widest text-secondary mb-8 inline-flex items-center gap-2">
<span aria-hidden="true">&larr;</span> All Insights
</a>
<span class="font-ea-label-sm text-ea-label-sm uppercase tracking-widest text-secondary mb-4 block">{post.category}</span>
<h1 class="font-display-lg text-display-lg-mobile md:text-display-lg text-primary mb-8">{post.title}</h1>
<div class="flex items-center gap-6 font-ea-label-sm text-ea-label-sm text-on-surface-variant uppercase tracking-widest pb-8 mb-8 border-b border-outline/10">
<span>{post.author}</span>
<span>{post.date}</span>
<span>{post.readTime}</span>
</div>
<div class="space-y-6">
{post.body.map((paragraph) => (
<p class="font-body-lg text-body-lg text-on-surface-variant leading-relaxed">{paragraph}</p>
))}
</div>
</div>
{related.length > 0 && (
<div class="max-w-ea-container-max mx-auto px-margin-desktop mt-stack-lg pt-stack-lg border-t border-outline/10">
<h2 class="font-ea-headline-md text-ea-headline-md text-primary mb-8">More Insights</h2>
<div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
{related.map((p) => (
<a href={`/templates/accounting-luxury/blog/${p.slug}`} class="group bg-white p-8 luxury-shadow">
<span class="font-ea-label-sm text-ea-label-sm uppercase tracking-widest text-secondary mb-4 block">{p.category}</span>
<h3 class="font-headline-sm text-headline-sm text-primary group-hover:text-secondary transition-colors">{p.title}</h3>
</a>
))}
</div>
</div>
)}
</TemplateLayout>
