---
import TemplateLayout from "@/templates/accounting-luxury/TemplateLayout.astro";
import { blogPosts } from "@/lib/blog";

const posts = blogPosts["accounting-luxury"];
---

<TemplateLayout
  title="Insights | Estate & Accord"
  description="Strategic perspectives on wealth preservation, tax efficiency, and multi-generational estate planning from Estate & Accord's advisory team."
  active="blog"
  canonicalPath="/templates/accounting-luxury/blog"
>
<div class="max-w-ea-container-max mx-auto px-margin-desktop">
<section class="mb-stack-lg">
<span class="font-ea-label-sm text-ea-label-sm uppercase tracking-widest text-secondary mb-4 block">Strategic Insights</span>
<h1 class="font-display-lg text-display-lg-mobile md:text-display-lg text-primary mb-6">Advisory Insights</h1>
<p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl">Perspectives on wealth preservation, cross-border tax strategy, and multi-generational governance from Estate &amp; Accord's principals.</p>
</section>
<section class="grid grid-cols-1 md:grid-cols-2 gap-gutter pb-stack-lg">
{posts.map((post) => (
<a href={`/templates/accounting-luxury/blog/${post.slug}`} class="group bg-white p-8 luxury-shadow flex flex-col">
<span class="font-ea-label-sm text-ea-label-sm uppercase tracking-widest text-secondary mb-4 block">{post.category}</span>
<h2 class="font-headline-sm text-headline-sm text-primary mb-4 group-hover:text-secondary transition-colors">{post.title}</h2>
<p class="font-body-md text-on-surface-variant mb-6 flex-grow">{post.excerpt}</p>
<div class="flex items-center justify-between font-ea-label-sm text-ea-label-sm text-on-surface-variant uppercase tracking-widest pt-4 border-t border-outline/10">
<span>{post.date}</span>
<span>{post.readTime}</span>
</div>
</a>
))}
</section>
</div>
</TemplateLayout>
