---
import TemplateLayout from "@/templates/accounting-zen/TemplateLayout.astro";
import { blogPosts } from "@/lib/blog";

const posts = blogPosts["accounting-zen"];
---

<TemplateLayout
  title="Journal | Zen Ledger Advisory"
  description="Notes on financial clarity, tax strategy, and structural governance from Zen Ledger Advisory."
  active="blog"
  canonicalPath="/templates/accounting-zen/blog"
>
<main class="pt-40 max-w-zl-container-max mx-auto px-margin-desktop">
<section class="mb-section-gap">
<p class="text-zl-label-sm font-zl-label-sm uppercase tracking-[0.2em] text-on-surface-variant mb-6">The Journal</p>
<h1 class="font-zl-display text-zl-display mb-8">Considered Thinking.</h1>
<p class="text-on-surface-variant leading-relaxed max-w-2xl">Notes on financial clarity, quarterly tax strategy, and structural governance — written the way we advise: without excess.</p>
</section>
<section class="grid grid-cols-1 md:grid-cols-2 gap-gutter pb-section-gap">
{posts.map((post) => (
<a href={`/templates/accounting-zen/blog/${post.slug}`} class="group border-t border-outline-variant pt-8 flex flex-col">
<span class="text-zl-label-sm font-zl-label-sm text-on-surface-variant opacity-50 block mb-4 uppercase tracking-widest">{post.category}</span>
<h2 class="font-zl-display text-zl-headline-lg mb-4 group-hover:text-primary transition-colors">{post.title}</h2>
<p class="text-zl-body-md font-zl-body-md text-on-surface-variant mb-6 flex-grow leading-relaxed">{post.excerpt}</p>
<div class="flex items-center justify-between text-zl-label-sm font-zl-label-sm text-on-surface-variant uppercase tracking-widest">
<span>{post.date}</span>
<span>{post.readTime}</span>
</div>
</a>
))}
</section>
</main>
</TemplateLayout>
