---
import TemplateLayout from "@/templates/accounting-editorial/TemplateLayout.astro";
import { blogPosts } from "@/lib/blog";

export function getStaticPaths() {
  return blogPosts["accounting-editorial"].map((post) => ({
    params: { post: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const related = blogPosts["accounting-editorial"].filter((p) => p.slug !== post.slug).slice(0, 2);
---

<TemplateLayout
  title={`${post.title} | Strategic Insight Advisory`}
  description={post.excerpt}
  active="blog"
  canonicalPath={`/templates/accounting-editorial/blog/${post.slug}`}
>
<main class="pt-24 max-w-si-container-max mx-auto px-si-margin-desktop py-section-padding">
<div class="max-w-3xl mx-auto">
<a href="/templates/accounting-editorial/knowledge-hub" class="font-si-label-lg text-si-label-lg uppercase tracking-widest text-secondary mb-8 inline-flex items-center gap-2">
<span aria-hidden="true">&larr;</span> Knowledge Hub
</a>
<span class="bg-secondary text-on-primary px-3 py-1 text-[10px] font-bold uppercase tracking-widest w-fit mb-6 inline-block">{post.category}</span>
<h1 class="font-si-display-lg text-si-display-lg-mobile md:text-si-display-lg text-primary mb-8">{post.title}</h1>
<div class="flex items-center gap-6 font-si-label-lg text-si-label-lg text-on-surface-variant uppercase tracking-widest pb-8 mb-8 border-b border-outline-variant">
<span>{post.author}</span>
<span>{post.date}</span>
<span>{post.readTime}</span>
</div>
<div class="space-y-6">
{post.body.map((paragraph) => (
<p class="font-si-body-lg text-si-body-lg text-on-surface-variant leading-relaxed">{paragraph}</p>
))}
</div>
</div>
{related.length > 0 && (
<div class="mt-section-padding pt-section-padding border-t border-outline-variant">
<h2 class="font-si-headline-lg text-si-headline-lg text-primary mb-8">More Insights</h2>
<div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
{related.map((p) => (
<a href={`/templates/accounting-editorial/blog/${p.slug}`} class="group bg-surface-container-low p-8 editorial-shadow">
<span class="bg-secondary text-on-primary px-3 py-1 text-[10px] font-bold uppercase tracking-widest w-fit mb-4">{p.category}</span>
<h3 class="font-si-headline-sm text-si-headline-sm text-primary group-hover:text-secondary transition-colors">{p.title}</h3>
</a>
))}
</div>
</div>
)}
</main>
</TemplateLayout>
