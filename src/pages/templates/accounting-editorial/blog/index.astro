---
import TemplateLayout from "@/templates/accounting-editorial/TemplateLayout.astro";
import { blogPosts } from "@/lib/blog";

const posts = blogPosts["accounting-editorial"];
---

<TemplateLayout
  title="All Insights | Strategic Insight Advisory"
  description="The full archive of strategic viewpoints, tax updates, and advisory perspective from Strategic Insight Advisory."
  active="blog"
  canonicalPath="/templates/accounting-editorial/blog"
>
<main class="pt-24">
<section class="max-w-si-container-max mx-auto px-si-margin-desktop py-section-padding">
<div class="flex items-center space-x-2 mb-6">
<span class="w-8 h-[1px] bg-secondary"></span>
<span class="font-si-label-lg text-si-label-lg text-secondary uppercase tracking-widest">Full Archive</span>
</div>
<h1 class="font-si-display-lg text-si-display-lg-mobile md:text-si-display-lg text-primary max-w-xl mb-16">All Insights.</h1>
<div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
{posts.map((post) => (
<a href={`/templates/accounting-editorial/blog/${post.slug}`} class="group bg-surface-container-low p-8 editorial-shadow flex flex-col">
<span class="bg-secondary text-on-primary px-3 py-1 text-[10px] font-bold uppercase tracking-widest w-fit mb-4">{post.category}</span>
<h2 class="font-si-headline-sm text-si-headline-sm text-primary group-hover:text-secondary transition-colors mb-4">{post.title}</h2>
<p class="font-si-body-md text-si-body-md text-on-surface-variant mb-6 flex-grow">{post.excerpt}</p>
<div class="flex items-center justify-between font-si-label-lg text-si-label-lg text-on-surface-variant uppercase tracking-widest pt-4 border-t border-outline-variant">
<span>{post.date}</span>
<span>{post.readTime}</span>
</div>
</a>
))}
</div>
</section>
</main>
</TemplateLayout>
