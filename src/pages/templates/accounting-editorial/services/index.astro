---
import TemplateLayout from "@/templates/accounting-editorial/TemplateLayout.astro";
---

<TemplateLayout
  title="Our Services | Strategic Insight Advisory"
  description="Advisory, Assurance, Outsourcing, and Tax — Strategic Insight Advisory's core service lines."
  active="services"
  canonicalPath="/templates/accounting-editorial/services"
>
<main class="mt-[80px]">
<!-- Hero Section / Header -->
<section class="relative pt-section-padding pb-24 px-si-margin-desktop max-w-si-container-max mx-auto">
<div class="max-w-2xl">
<span class="text-secondary font-si-label-lg text-si-label-lg tracking-widest uppercase mb-4 block">Key Services</span>
<h1 class="font-si-display-lg text-si-display-lg text-primary mb-8 text-balanced leading-tight">Let's find your way.</h1>
<p class="text-si-body-lg text-on-surface-variant leading-relaxed">
                    Navigating the complexities of business requires more than just numbers. It requires a partner who sees the path ahead. Our suite of services is designed to provide clarity, stability, and growth.
                </p>
</div>
<!-- Path Line Element -->
<svg class="absolute right-0 top-0 w-1/2 h-full opacity-20 -z-10" viewbox="0 0 400 400">
<path d="M400,50 Q300,50 300,150 T200,250 T0,250" fill="none" stroke="#a23f00" stroke-width="1"></path>
<rect class="fill-secondary" height="10" width="10" x="295" y="145"></rect>
<rect class="fill-primary" height="10" width="10" x="195" y="245"></rect>
</svg>
</section>
<!-- Services Grid -->
<section class="bg-surface-bright py-section-padding border-t border-outline-variant">
<div class="max-w-si-container-max mx-auto px-si-margin-desktop">
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-gutter">
<!-- Advisory -->
<div class="group relative bg-white p-10 border border-outline-variant hover:border-secondary transition-all h-full flex flex-col">
<div class="w-16 h-16 bg-surface-container mb-8 flex items-center justify-center relative">
<span class="material-symbols-outlined text-secondary text-3xl" data-icon="insights" style="font-variation-settings: 'FILL' 1;">insights</span>
<div class="absolute -top-1 -right-1 w-3 h-3 bg-secondary"></div>
</div>
<h3 class="font-si-headline-sm text-si-headline-sm text-primary mb-4">Advisory</h3>
<p class="text-on-surface-variant mb-auto leading-relaxed">
                            Navigating all the complexities beyond the spreadsheets to accelerate your growth and strategic positioning.
                        </p>
<a class="mt-8 flex items-center text-secondary font-si-label-lg text-si-label-lg uppercase tracking-widest hover:gap-2 transition-all" href="/templates/accounting-editorial/contact">
                            Learn More <span class="material-symbols-outlined ml-2 text-sm" data-icon="arrow_forward">arrow_forward</span>
</a>
</div>
<!-- Assurance -->
<div class="group relative bg-white p-10 border border-outline-variant hover:border-secondary transition-all h-full flex flex-col">
<div class="w-16 h-16 bg-surface-container mb-8 flex items-center justify-center relative">
<span class="material-symbols-outlined text-secondary text-3xl" data-icon="verified_user" style="font-variation-settings: 'FILL' 1;">verified_user</span>
<div class="absolute -top-1 -right-1 w-3 h-3 bg-primary"></div>
</div>
<h3 class="font-si-headline-sm text-si-headline-sm text-primary mb-4">Assurance</h3>
<p class="text-on-surface-variant mb-auto leading-relaxed">
                            Turning numbers into knowledge to confidently solve complex business problems and seize opportunities.
                        </p>
<a class="mt-8 flex items-center text-secondary font-si-label-lg text-si-label-lg uppercase tracking-widest hover:gap-2 transition-all" href="/templates/accounting-editorial/contact">
                            Learn More <span class="material-symbols-outlined ml-2 text-sm" data-icon="arrow_forward">arrow_forward</span>
</a>
</div>
<!-- Outsourcing -->
<div class="group relative bg-white p-10 border border-outline-variant hover:border-secondary transition-all h-full flex flex-col">
<div class="w-16 h-16 bg-surface-container mb-8 flex items-center justify-center relative">
<span class="material-symbols-outlined text-secondary text-3xl" data-icon="account_tree" style="font-variation-settings: 'FILL' 1;">account_tree</span>
<div class="absolute -top-1 -right-1 w-3 h-3 bg-secondary"></div>
</div>
<h3 class="font-si-headline-sm text-si-headline-sm text-primary mb-4">Outsourcing</h3>
<p class="text-on-surface-variant mb-auto leading-relaxed">
                            Embracing true collaboration to fulfill your back-office operations and transform your decision-making power.
                        </p>
<a class="mt-8 flex items-center text-secondary font-si-label-lg text-si-label-lg uppercase tracking-widest hover:gap-2 transition-all" href="/templates/accounting-editorial/contact">
                            Learn More <span class="material-symbols-outlined ml-2 text-sm" data-icon="arrow_forward">arrow_forward</span>
</a>
</div>
<!-- Tax -->
<div class="group relative bg-white p-10 border border-outline-variant hover:border-secondary transition-all h-full flex flex-col">
<div class="w-16 h-16 bg-surface-container mb-8 flex items-center justify-center relative">
<span class="material-symbols-outlined text-secondary text-3xl" data-icon="account_balance" style="font-variation-settings: 'FILL' 1;">account_balance</span>
<div class="absolute -top-1 -right-1 w-3 h-3 bg-primary"></div>
</div>
<h3 class="font-si-headline-sm text-si-headline-sm text-primary mb-4">Tax</h3>
<p class="text-on-surface-variant mb-auto leading-relaxed">
                            Confidently connecting the dots between compliance and strategy while uncomplicating tax matters.
                        </p>
<a class="mt-8 flex items-center text-secondary font-si-label-lg text-si-label-lg uppercase tracking-widest hover:gap-2 transition-all" href="/templates/accounting-editorial/services/tax-strategy">
                            Learn More <span class="material-symbols-outlined ml-2 text-sm" data-icon="arrow_forward">arrow_forward</span>
</a>
</div>
</div>
</div>
</section>
<!-- Dynamic Content Section -->
<section class="py-24 bg-primary relative overflow-hidden">

<div class="max-w-si-container-max mx-auto px-si-margin-desktop relative z-10 flex flex-col md:flex-row items-center justify-between gap-12">
<div class="max-w-xl">
<h2 class="font-si-headline-lg text-si-headline-lg text-white mb-6">The Path Forward in a Shifting Landscape.</h2>
<p class="text-white opacity-80 text-si-body-lg">
                        We don't just react to change; we anticipate it. Join our network of experts as we navigate the evolving regulatory and financial environment together.
                    </p>
</div>
<button class="bg-secondary text-white px-10 py-4 font-si-label-lg text-si-label-lg uppercase tracking-widest hover:bg-opacity-90 transition-all flex items-center group">
                    View Industry Insights
                    <span class="material-symbols-outlined ml-3 group-hover:translate-x-1 transition-transform" data-icon="trending_up">trending_up</span>
</button>
</div>
</section>
<!-- Upcoming Events Section -->
<section class="bg-primary pt-section-padding pb-section-padding">
<div class="max-w-si-container-max mx-auto px-si-margin-desktop">
<div class="flex justify-between items-end mb-16 border-b border-white/10 pb-8">
<h2 class="font-si-display-lg text-si-display-lg text-white">Upcoming Events</h2>
<a class="text-white font-si-label-lg text-si-label-lg flex items-center opacity-70 hover:opacity-100 transition-all" href="/templates/accounting-editorial/contact">
<span class="material-symbols-outlined mr-2" data-icon="arrow_right">arrow_right</span> SEE ALL EVENTS
                    </a>
</div>
<div class="grid grid-cols-1 lg:grid-cols-2 gap-gutter">
<!-- Featured Event -->
<div class="bg-white p-0 relative group overflow-hidden">
<div class="p-12 h-full flex flex-col relative z-10">
<h3 class="font-si-headline-md text-si-headline-md text-primary mb-4 leading-tight">Supervisory Committee &amp; Board of Directors Conference</h3>
<span class="text-secondary font-si-label-lg text-si-label-lg tracking-widest uppercase">EVENT — SAVANNAH, GA</span>
<div class="mt-auto pt-16 flex items-end justify-between">
<div class="text-primary opacity-30 font-si-display-lg text-si-display-lg uppercase leading-none">July</div>
<div class="text-primary font-si-display-lg text-si-display-lg leading-none">19</div>
</div>
</div>
<!-- Graphic Corner -->
<div class="absolute bottom-0 right-0 w-48 h-48 bg-surface-container-highest/20 rotate-45 translate-x-24 translate-y-24"></div>
</div>
<!-- Stacked Small Events -->
<div class="flex flex-col gap-gutter">
<!-- Small Event 1 -->
<div class="bg-surface-container-highest/10 p-8 flex justify-between items-center group hover:bg-surface-container-highest/20 transition-all border border-white/5">
<div>
<h4 class="font-si-headline-sm text-si-headline-sm text-white mb-2">2026 Houston Perspectives Conference</h4>
<span class="text-secondary-fixed-dim font-si-label-lg text-si-label-lg uppercase">EVENT — HOUSTON, TX</span>
</div>
<div class="text-right ml-8">
<div class="text-white opacity-40 font-si-label-lg text-si-label-lg uppercase">August</div>
<div class="text-white font-si-headline-lg text-si-headline-lg leading-none">06</div>
</div>
</div>
<!-- Small Event 2 -->
<div class="bg-surface-container-highest/10 p-8 flex justify-between items-center group hover:bg-surface-container-highest/20 transition-all border border-white/5">
<div>
<h4 class="font-si-headline-sm text-si-headline-sm text-white mb-2">Credit Union Financial Leadership Exchange</h4>
<span class="text-secondary-fixed-dim font-si-label-lg text-si-label-lg uppercase">EVENT — SAVANNAH, GA</span>
</div>
<div class="text-right ml-8">
<div class="text-white opacity-40 font-si-label-lg text-si-label-lg uppercase">August</div>
<div class="text-white font-si-headline-lg text-si-headline-lg leading-none">09</div>
</div>
</div>
</div>
</div>
</div>
</section>
<!-- Newsletter Sub-section -->
<section class="bg-surface-container-low py-12">
<div class="max-w-si-container-max mx-auto px-si-margin-desktop flex flex-col md:flex-row items-center justify-between">
<h4 class="font-si-headline-sm text-si-headline-sm text-primary mb-4 md:mb-0">Receive emails <span class="italic font-normal">worth</span> reading</h4>
<div class="flex w-full md:w-auto">
<input class="bg-transparent border-b border-outline-variant focus:border-secondary outline-none px-4 py-2 w-full md:w-64 font-si-body-md" placeholder="Email Address" type="email"/>
<button class="bg-secondary text-white px-8 py-3 font-si-label-lg text-si-label-lg uppercase tracking-widest whitespace-nowrap ml-4">Subscribe to VIEWpoints</button>
</div>
</div>
</section>
</main>

</TemplateLayout>
