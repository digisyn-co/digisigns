---
import TemplateLayout from "@/templates/accounting-editorial/TemplateLayout.astro";
---

<TemplateLayout
  title="Contact Us | Strategic Insight Advisory"
  description="Reach Strategic Insight Advisory's Houston headquarters or start a conversation."
  active="contact"
  canonicalPath="/templates/accounting-editorial/contact"
>
<main class="relative">
<!-- SVG Path Decoration -->
<svg class="absolute top-0 left-0 w-full h-full pointer-events-none opacity-40" xmlns="http://www.w3.org/2000/svg">
<path d="M0,200 Q200,100 400,300 T800,200 T1200,400" fill="none" stroke="#d2c2cd" stroke-width="1"></path>
<circle cx="1200" cy="400" fill="#a23f00" r="4"></circle>
<rect fill="#a23f00" height="10" transform="rotate(45 400 300)" width="10" x="395" y="295"></rect>
</svg>
<!-- Hero Section -->
<section class="max-w-7xl mx-auto px-si-margin-desktop py-section-padding relative">
<div class="grid grid-cols-1 md:grid-cols-2 gap-gutter items-center">
<div>
<h1 class="font-si-display-lg text-si-display-lg text-primary mb-6">Begin Your Journey.</h1>
<p class="font-si-body-lg text-si-body-lg text-on-surface-variant max-w-md mb-8">
                        Strategic clarity begins with a single conversation. Whether you're navigating complex tax laws or seeking a long-term growth partner, we're here to light the way.
                    </p>
<div class="flex items-center gap-4 text-primary">
<div class="w-12 h-px bg-secondary"></div>
<span class="font-si-label-lg text-si-label-lg uppercase tracking-widest">Connect with Expertise</span>
</div>
</div>
<div class="relative">
<div class="bg-primary-container p-12 aspect-square flex flex-col justify-center text-on-primary relative z-10">
<span class="material-symbols-outlined text-6xl text-secondary mb-6" style="font-variation-settings: 'FILL' 1;">emergency_home</span>
<h2 class="font-si-headline-md text-si-headline-md mb-2">Emergency Advisory</h2>
<p class="font-si-body-md text-si-body-md opacity-80 mb-6">For critical situations requiring immediate intellectual intervention.</p>
<a class="text-secondary-fixed text-4xl font-bold font-si-headline-md" href="tel:8888709873">888.870.9873</a>
</div>
<div class="absolute -bottom-6 -right-6 w-full h-full bg-secondary-fixed -z-10"></div>
</div>
</div>
</section>
<!-- Multi-Step Inquiry Form -->
<section class="bg-surface-container-low py-section-padding relative overflow-hidden">
<div class="max-w-4xl mx-auto px-si-margin-desktop">
<div class="mb-12 flex items-center justify-between">
<div class="step-active flex items-center gap-2" id="step-indicator-1">
<span class="font-si-label-lg">01</span>
<span class="uppercase tracking-widest font-bold">Identity</span>
</div>
<div class="step-line"></div>
<div class="text-outline flex items-center gap-2" id="step-indicator-2">
<span class="font-si-label-lg">02</span>
<span class="uppercase tracking-widest font-bold">Challenge</span>
</div>
<div class="step-line"></div>
<div class="text-outline flex items-center gap-2" id="step-indicator-3">
<span class="font-si-label-lg">03</span>
<span class="uppercase tracking-widest font-bold">Refinement</span>
</div>
</div>
<div class="bg-white p-12 border border-outline-variant shadow-sm transition-all duration-500" id="form-container">
<!-- Step 1 Content -->
<div class="space-y-8" id="step-1">
<h3 class="font-si-headline-sm text-si-headline-sm text-primary mb-6">Who are we speaking with?</h3>
<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
<div class="flex flex-col gap-2">
<label class="font-si-label-lg text-si-label-lg text-on-surface-variant uppercase">Full Name</label>
<input class="border-b border-outline bg-transparent py-2 font-si-body-md form-input-focus transition-all" placeholder="John Doe" type="text"/>
</div>
<div class="flex flex-col gap-2">
<label class="font-si-label-lg text-si-label-lg text-on-surface-variant uppercase">Organization</label>
<input class="border-b border-outline bg-transparent py-2 font-si-body-md form-input-focus transition-all" placeholder="Global Logistics Co." type="text"/>
</div>
<div class="flex flex-col gap-2 md:col-span-2">
<label class="font-si-label-lg text-si-label-lg text-on-surface-variant uppercase">Email Address</label>
<input class="border-b border-outline bg-transparent py-2 font-si-body-md form-input-focus transition-all" placeholder="john@enterprise.com" type="email"/>
</div>
</div>
<div class="pt-8 flex justify-end">
<button class="bg-primary text-on-primary px-8 py-4 font-si-label-lg text-si-label-lg uppercase font-bold flex items-center gap-4 hover:bg-primary-container transition-all" onclick="goToStep(2)">
                                Continue Path
                                <span class="material-symbols-outlined">trending_flat</span>
</button>
</div>
</div>
<!-- Step 2 Content (Hidden) -->
<div class="hidden space-y-8" id="step-2">
<h3 class="font-si-headline-sm text-si-headline-sm text-primary mb-6">What is the nature of your challenge?</h3>
<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
<button class="border border-outline-variant p-6 text-left hover:border-secondary hover:bg-secondary-fixed transition-all group">
<span class="material-symbols-outlined text-secondary mb-4">analytics</span>
<p class="font-si-label-lg font-bold">Tax &amp; Assurance</p>
</button>
<button class="border border-outline-variant p-6 text-left hover:border-secondary hover:bg-secondary-fixed transition-all group">
<span class="material-symbols-outlined text-secondary mb-4">strategy</span>
<p class="font-si-label-lg font-bold">Strategic Advisory</p>
</button>
<button class="border border-outline-variant p-6 text-left hover:border-secondary hover:bg-secondary-fixed transition-all group">
<span class="material-symbols-outlined text-secondary mb-4">settings_suggest</span>
<p class="font-si-label-lg font-bold">Process Outsourcing</p>
</button>
<button class="border border-outline-variant p-6 text-left hover:border-secondary hover:bg-secondary-fixed transition-all group">
<span class="material-symbols-outlined text-secondary mb-4">gavel</span>
<p class="font-si-label-lg font-bold">Litigation Support</p>
</button>
</div>
<div class="pt-8 flex justify-between">
<button class="text-primary font-si-label-lg text-si-label-lg uppercase font-bold flex items-center gap-2 opacity-60 hover:opacity-100 transition-all" onclick="goToStep(1)">
<span class="material-symbols-outlined">west</span>
                                Back
                            </button>
<button class="bg-primary text-on-primary px-8 py-4 font-si-label-lg text-si-label-lg uppercase font-bold flex items-center gap-4 hover:bg-primary-container transition-all" onclick="goToStep(3)">
                                Narrow Scope
                                <span class="material-symbols-outlined">trending_flat</span>
</button>
</div>
</div>
<!-- Step 3 Content (Hidden) -->
<div class="hidden space-y-8" id="step-3">
<h3 class="font-si-headline-sm text-si-headline-sm text-primary mb-6">Final Refinements</h3>
<div class="flex flex-col gap-2">
<label class="font-si-label-lg text-si-label-lg text-on-surface-variant uppercase">Detailed Brief</label>
<textarea class="border border-outline bg-transparent p-4 font-si-body-md form-input-focus transition-all" placeholder="Briefly describe your objectives or immediate concerns..." rows="4"></textarea>
</div>
<div class="flex items-center gap-4 p-4 bg-surface-container-low border-l-4 border-secondary">
<span class="material-symbols-outlined text-secondary">info</span>
<p class="font-si-body-md text-sm italic">Expect a response from a specialized partner within 12 business hours.</p>
</div>
<div class="pt-8 flex justify-between">
<button class="text-primary font-si-label-lg text-si-label-lg uppercase font-bold flex items-center gap-2 opacity-60 hover:opacity-100 transition-all" onclick="goToStep(2)">
<span class="material-symbols-outlined">west</span>
                                Back
                            </button>
<button class="bg-secondary text-on-primary px-10 py-4 font-si-label-lg text-si-label-lg uppercase font-bold flex items-center gap-4 hover:brightness-110 transition-all">
                                Initiate Consultation
                                <span class="material-symbols-outlined">check_circle</span>
</button>
</div>
</div>
</div>
</div>
</section>
<!-- Global Presence (Maps) -->
<section class="max-w-7xl mx-auto px-si-margin-desktop py-section-padding">
<div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
<div>
<h2 class="font-si-headline-lg text-si-headline-lg text-primary">Strategic Hubs.</h2>
<p class="font-si-body-lg text-si-body-lg text-on-surface-variant mt-4 max-w-lg">Our physical locations serve as command centers for global insight.</p>
</div>
<div class="flex gap-4">
<button class="px-6 py-2 border-b-2 border-secondary font-bold text-primary">HOUSTON</button>
<button class="px-6 py-2 text-outline-variant hover:text-primary transition-all">DETROIT</button>
<button class="px-6 py-2 text-outline-variant hover:text-primary transition-all">MIAMI</button>
<button class="px-6 py-2 text-outline-variant hover:text-primary transition-all">GRAND RAPIDS</button>
</div>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
<div class="md:col-span-2 group overflow-hidden border border-outline-variant relative h-[500px]">
<div class="absolute inset-0 grayscale group-hover:grayscale-0 transition-all duration-700">
<img class="w-full h-full object-cover" data-alt="A high-contrast architectural map of Houston's downtown business district, rendered in a clean corporate style with deep plum and orange accent marks indicating the office location. The lighting is bright and clear, reflecting a light-mode modern aesthetic. The atmosphere is professional and authoritative, with crisp lines and minimal clutter." src="https://lh3.googleusercontent.com/aida-public/AB6AXuBPUzht2rnJAZjaq6FNtzC4n3UFbWWwu4X4wJCQFG1xQxjLiE6iTtiOLf2SupdiP3ypDFlhuhDcixgr6uy-RAW3liU_Up8Fza5tXzlKA0r9-1-Mvwxv6Oxdy3lhWoI2Wizg6xd4Z3otMayY4sGQkKAnaGQFD-YHAwXFxNX2LmQmmErbzMiK19evS2pZRX6_-VoEqsWT463hp6mCu_XRFp-YhGNsXAFaOP9D5CW8NRHoe8OSY1JpO1UYFQgaaLyDLzOiaSmLRpFqLJPN"/>
</div>
<div class="absolute bottom-0 left-0 bg-primary text-on-primary p-8 max-w-sm">
<h4 class="font-si-headline-sm text-si-headline-sm mb-2">Houston HQ</h4>
<p class="font-si-body-md opacity-80 mb-4">2901 West Loop South, Suite 500<br/>Houston, Texas 77027</p>
<a class="text-secondary-fixed font-bold flex items-center gap-2 group" href="https://www.google.com/maps/search/?api=1&query=2901+West+Loop+South+Suite+500+Houston+Texas+77027" target="_blank" rel="noopener">
                            Get Directions 
                            <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
</a>
</div>
</div>
<div class="flex flex-col gap-gutter">
<div class="bg-white border border-outline-variant p-8 flex-1 flex flex-col justify-between">
<div>
<span class="font-si-label-lg text-secondary uppercase tracking-widest mb-4 block">Central Command</span>
<h4 class="font-si-headline-sm text-si-headline-sm text-primary mb-2">Detroit</h4>
<p class="font-si-body-md text-on-surface-variant">305 West Big Beaver Road<br/>Troy, Michigan 48084</p>
</div>
<p class="font-si-label-lg font-bold mt-4">248.244.3000</p>
</div>
<div class="bg-white border border-outline-variant p-8 flex-1 flex flex-col justify-between">
<div>
<span class="font-si-label-lg text-secondary uppercase tracking-widest mb-4 block">Global Gateway</span>
<h4 class="font-si-headline-sm text-si-headline-sm text-primary mb-2">Miami</h4>
<p class="font-si-body-md text-on-surface-variant">2525 Ponce de Leon Blvd<br/>Coral Gables, Florida 33134</p>
</div>
<p class="font-si-label-lg font-bold mt-4">305.441.2222</p>
</div>
</div>
</div>
</section>
<!-- Newsletter / Footer CTA -->
<section class="bg-primary py-16">
<div class="max-w-7xl mx-auto px-si-margin-desktop flex flex-col md:flex-row justify-between items-center gap-8">
<h3 class="font-si-headline-sm text-si-headline-sm text-on-primary">Receive emails <span class="italic text-secondary-fixed">worth</span> reading</h3>
<div class="flex w-full md:w-auto gap-0 border border-outline-variant/30">
<input class="bg-white/5 border-none text-on-primary px-6 py-4 w-full md:w-80 focus:ring-1 focus:ring-secondary" placeholder="Your professional email" type="email"/>
<button class="bg-secondary text-on-primary px-8 py-4 font-si-label-lg text-si-label-lg uppercase font-bold whitespace-nowrap hover:brightness-110 transition-all">
                        Subscribe
                    </button>
</div>
</div>
</section>
</main>

</TemplateLayout>
