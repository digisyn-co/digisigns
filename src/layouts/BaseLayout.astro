---
// Shared HTML shell used by EVERY page on the platform, including the
// Template Library itself and every page inside every template.
// It only owns: <html>/<head> plumbing, the CSS reset, and SEO tags.
// It does NOT own navigation, footer, colors, or type — those are
// authored per-template in src/styles/themes/<slug>.css and layered on
// by each template's own TemplateLayout (src/templates/<slug>/TemplateLayout.astro).
//
// IMPORTANT bundling note: plain CSS side-effect imports (`import "./x.css"`)
// only reliably get included in the production build when they're imported
// directly from THIS file — Astro/Vite silently drops equivalent imports
// made from a page's frontmatter or from a nested non-page component (e.g.
// TemplateLayout.astro) two-plus levels away from the page entrypoint, even
// though the component itself renders fine. So every theme file, though
// authored and owned per-template, must ALSO be registered with a single
// import line here. Add one line per new template; do not move the theme
// files themselves out of src/styles/themes/.
import SEO from "@/components/SEO.astro";
import "@/styles/global.css";
import "@/styles/themes/digisigns.css";
import "@/styles/themes/accounting-luxury.css";
import "@/styles/themes/law-prestige.css";
import "@/styles/themes/movers-premium.css";
import "@/styles/themes/creative-studio.css";
import "@/styles/themes/accounting-precision.css";
import "@/styles/themes/accounting-editorial.css";

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  bodyClass?: string;
  htmlClass?: string;
  // Every template page gets a slim "back to home" banner pinned above its
  // own nav, linking to the DigiSigns root ("/"). The root landing page
  // itself sets this to false (it IS home; a link back to itself would be
  // circular). Height is a fixed 2.5rem (h-10) — see the accounting-luxury
  // Nav's `top-10` offset, which exists specifically to sit below this bar
  // since that template's nav uses `fixed` instead of `sticky`/static
  // positioning and can't rely on normal sticky stacking.
  showBackToHome?: boolean;
}

const { title, description, canonicalPath, ogImage, bodyClass, htmlClass, showBackToHome = true } = Astro.props;
---

<!doctype html>
<html lang="en" class={htmlClass}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO title={title} description={description} canonicalPath={canonicalPath} ogImage={ogImage} />
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    {showBackToHome && (
      <div class="sticky top-0 z-[60] h-10 flex items-center justify-center bg-zinc-900 text-zinc-100 px-4">
        <a href="/" class="flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider hover:text-white transition-colors">
          <span aria-hidden="true">&larr;</span>
          Back to DigiSigns Template Collection
        </a>
      </div>
    )}
    <slot />

    <!--
      Site-wide interaction layer (platform chrome, not template-specific).
      Two generic, data-attribute-driven behaviors used by every template's
      Nav.astro and every contact form:

      1. Mobile nav: a <button data-mobile-menu-toggle="#selector"> toggles
         the `.mobile-menu-open` class on the element matching #selector.
         `.mobile-menu-open` is layout-only (position/display) below; each
         Nav supplies its own background/border/text color via ordinary
         Tailwind utility classes (which already resolve per-theme), so no
         per-template CSS is needed here.
      2. Contact forms: any <form data-success-target="#selector"> has its
         submit intercepted, hides itself, and reveals the element matching
         #selector (a pre-built confirmation/thank-you state). No backend
         exists for these demo templates, so this is the honest, complete
         behavior for a static form.
    -->
    <style is:global>
      .mobile-menu-open {
        display: flex !important;
        flex-direction: column !important;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        z-index: 55;
        padding: 1.5rem;
        gap: 1rem;
      }
    </style>
    <script>
      function wireMobileMenus() {
        document.querySelectorAll("[data-mobile-menu-toggle]").forEach((btn) => {
          if (btn.hasAttribute("data-wired")) return;
          btn.setAttribute("data-wired", "true");
          const selector = btn.getAttribute("data-mobile-menu-toggle");
          const menu = selector ? document.querySelector(selector) : null;
          if (!menu) return;
          btn.addEventListener("click", () => {
            const isOpen = menu.classList.toggle("mobile-menu-open");
            btn.setAttribute("aria-expanded", String(isOpen));
            const openIcon = btn.querySelector("[data-icon-open]");
            const closeIcon = btn.querySelector("[data-icon-close]");
            if (openIcon && closeIcon) {
              openIcon.classList.toggle("hidden", isOpen);
              closeIcon.classList.toggle("hidden", !isOpen);
            }
          });
          // Close the mobile panel automatically when a link inside it is
          // clicked (navigating away makes an open overlay stale) and when
          // the viewport grows past the mobile breakpoint.
          menu.querySelectorAll("a").forEach((a) => {
            a.addEventListener("click", () => menu.classList.remove("mobile-menu-open"));
          });
        });
        window.addEventListener("resize", () => {
          if (window.innerWidth >= 768) {
            document.querySelectorAll(".mobile-menu-open").forEach((el) => el.classList.remove("mobile-menu-open"));
          }
        });
      }

      function wireContactForms() {
        document.querySelectorAll("form[data-success-target]").forEach((form) => {
          if (form.hasAttribute("data-wired")) return;
          form.setAttribute("data-wired", "true");
          form.addEventListener("submit", (e) => {
            e.preventDefault();
            const selector = form.getAttribute("data-success-target");
            const target = selector ? document.querySelector(selector) : null;
            if (target) {
              form.classList.add("hidden");
              target.classList.remove("hidden");
              target.scrollIntoView({ behavior: "smooth", block: "center" });
            }
          });
        });
      }

      wireMobileMenus();
      wireContactForms();
    </script>
  </body>
</html>
