---
// Canonical footer normalized from Home. "Legal"/"Privacy" have no
// dedicated page in this 6-page build and route to Contact.
---

<footer class="w-full py-section-gap px-margin-mobile md:px-margin-desktop mt-section-gap border-t border-outline-variant bg-surface-container-low">
  <div class="max-w-container-max mx-auto flex flex-col md:flex-row justify-between items-start gap-gutter">
    <div class="max-w-xs">
      <div class="font-zl-display text-zl-headline-md text-primary mb-4">Zen Ledger Advisory</div>
      <p class="font-body-md text-body-md text-on-surface-variant italic">Precision in Silence.</p>
    </div>
    <div class="flex gap-16">
      <div class="flex flex-col gap-3">
        <span class="font-zl-label-sm text-zl-label-sm font-bold text-primary mb-2">Engage</span>
        <a class="text-on-surface-variant hover:text-primary underline decoration-from-font underline-offset-4 transition-all duration-500 font-body-md text-body-md" href="/templates/accounting-zen/contact">Dialogue</a>
        <a class="text-on-surface-variant hover:text-primary underline decoration-from-font underline-offset-4 transition-all duration-500 font-body-md text-body-md" href="/templates/accounting-zen/contact">Contact</a>
      </div>
      <div class="flex flex-col gap-3">
        <span class="font-zl-label-sm text-zl-label-sm font-bold text-primary mb-2">Resource</span>
        <a class="text-on-surface-variant hover:text-primary underline decoration-from-font underline-offset-4 transition-all duration-500 font-body-md text-body-md" href="/templates/accounting-zen/contact">Legal</a>
        <a class="text-on-surface-variant hover:text-primary underline decoration-from-font underline-offset-4 transition-all duration-500 font-body-md text-body-md" href="/templates/accounting-zen/contact">Privacy</a>
      </div>
    </div>
  </div>
  <div class="max-w-container-max mx-auto mt-24 pt-8 border-t border-outline-variant/30 flex justify-between items-center text-zl-label-sm font-zl-label-sm text-on-surface-variant">
    <span>© 2026 Zen Ledger Advisory. Precision in Silence.</span>
    <div class="flex gap-4 items-center">
      <span class="material-symbols-outlined">public</span>
      <span>Tokyo | London | New York</span>
    </div>
  </div>
</footer>
