---
// Canonical footer, normalized from the About/Practices/Contact screens'
// near-identical versions (richest link set kept, labels routed to real
// pages; Privacy/Terms/Regulatory Disclosures have no dedicated page in
// this 6-page build, so they route to Contact).
---

<footer class="w-full py-stack-lg bg-primary-container border-t border-outline/30">
  <div class="max-w-container-max mx-auto px-margin-desktop grid grid-cols-1 md:grid-cols-2 gap-gutter items-start">
    <div class="flex flex-col gap-8">
      <div class="font-display-lg text-display-lg text-on-primary-container uppercase">Prestige Law</div>
      <p class="font-body-md text-on-tertiary-container max-w-md">
        The standard in bespoke litigation. We provide meticulous counsel and strategic defense for the world's most complex legal challenges.
      </p>
    </div>
    <div class="grid grid-cols-2 gap-12 md:justify-self-end">
      <div class="flex flex-col gap-4">
        <span class="font-label-sm text-secondary-fixed uppercase tracking-widest mb-2">Firm</span>
        <a class="font-label-sm text-on-tertiary-container hover:text-secondary-fixed transition-colors uppercase tracking-widest" href="/templates/law-prestige/about">About</a>
        <a class="font-label-sm text-on-tertiary-container hover:text-secondary-fixed transition-colors uppercase tracking-widest" href="/templates/law-prestige/practices">Practices</a>
        <a class="font-label-sm text-on-tertiary-container hover:text-secondary-fixed transition-colors uppercase tracking-widest" href="/templates/law-prestige/industries">Industries</a>
      </div>
      <div class="flex flex-col gap-4">
        <span class="font-label-sm text-secondary-fixed uppercase tracking-widest mb-2">Engagement</span>
        <a class="font-label-sm text-on-tertiary-container hover:text-secondary-fixed transition-colors uppercase tracking-widest" href="/templates/law-prestige/contact">Privacy Policy</a>
        <a class="font-label-sm text-on-tertiary-container hover:text-secondary-fixed transition-colors uppercase tracking-widest" href="/templates/law-prestige/contact">Terms of Service</a>
        <a class="font-label-sm text-on-tertiary-container hover:text-secondary-fixed transition-colors uppercase tracking-widest" href="/templates/law-prestige/contact">Regulatory Disclosures</a>
      </div>
    </div>
    <div class="md:col-span-2 mt-16 pt-8 border-t border-white/10">
      <p class="font-label-sm text-on-tertiary-container uppercase tracking-widest">© 2026 Prestige Law LLP. All rights reserved. Registered in accordance with national legal authority regulations.</p>
    </div>
  </div>
</footer>
