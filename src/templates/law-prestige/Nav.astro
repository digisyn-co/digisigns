---
interface Props {
  active: "home" | "about" | "practices" | "industries" | "blog" | "contact";
}
const { active } = Astro.props;

const links = [
  { href: "/templates/law-prestige", label: "Home", key: "home" },
  { href: "/templates/law-prestige/about", label: "About", key: "about" },
  { href: "/templates/law-prestige/practices", label: "Practices", key: "practices" },
  { href: "/templates/law-prestige/industries", label: "Industries", key: "industries" },
  { href: "/templates/law-prestige/blog", label: "Insights", key: "blog" },
];
---

<nav class="w-full sticky top-10 z-50 bg-background border-b border-outline-variant/10">
  <div class="relative max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop flex justify-between items-center h-24">
    <a href="/templates/law-prestige" class="font-display-lg text-display-lg-mobile md:text-display-lg text-primary tracking-tighter">
      Prestige Law
    </a>
    <div id="mobile-menu-law-prestige" class="hidden lg:flex items-center space-x-10 bg-background border-t border-outline-variant/10 shadow-lg lg:shadow-none lg:border-0">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            "font-body-lg text-body-lg tracking-tight uppercase transition-colors",
            active === link.key
              ? "text-primary border-b-2 border-secondary font-bold pb-1"
              : "text-on-surface-variant hover:text-primary",
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
    <div class="flex items-center gap-4">
      <a
        href="/templates/law-prestige/contact"
        class:list={[
          "bg-primary text-on-primary px-8 py-3 font-label-md uppercase tracking-widest hover:bg-secondary transition-all duration-300",
          active === "contact" ? "bg-secondary" : "",
        ]}
      >
        Consultation
      </a>
      <button
        type="button"
        class="lg:hidden text-primary p-2"
        aria-label="Toggle menu"
        aria-expanded="false"
        data-mobile-menu-toggle="#mobile-menu-law-prestige"
      >
        <span class="material-symbols-outlined" data-icon-open>menu</span>
        <span class="material-symbols-outlined hidden" data-icon-close>close</span>
      </button>
    </div>
  </div>
</nav>
