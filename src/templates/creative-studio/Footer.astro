---
// Canonical footer normalized from Home (richest version). Newsletter
// form intercepts submit client-side (data-success-target) and shows a confirmation message; no backend exists to persist to. Social links (Instagram/Dribbble) route to Contact
// since there are no real accounts to link to.
---

<footer class="bg-surface-container-lowest w-full py-16 border-t border-outline-variant/20">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-gutter max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="space-y-6">
      <div class="font-cs-display-lg text-cs-headline-md font-black text-on-surface">The Creative Collective</div>
      <p class="text-on-surface-variant">Fueling the Creative Spark since 2018. Based globally, working locally with visionaries everywhere.</p>
    </div>
    <div class="space-y-4">
      <h5 class="font-cs-headline-md text-on-surface text-sm uppercase tracking-widest">Navigation</h5>
      <ul class="space-y-2">
        <li><a class="text-on-surface-variant hover:text-secondary hover:underline decoration-secondary decoration-2 underline-offset-4 transition-all" href="/templates/creative-studio">Home</a></li>
        <li><a class="text-on-surface-variant hover:text-secondary hover:underline decoration-secondary decoration-2 underline-offset-4 transition-all" href="/templates/creative-studio/services">Services</a></li>
        <li><a class="text-on-surface-variant hover:text-secondary hover:underline decoration-secondary decoration-2 underline-offset-4 transition-all" href="/templates/creative-studio/portfolio">Portfolio</a></li>
        <li><a class="text-on-surface-variant hover:text-secondary hover:underline decoration-secondary decoration-2 underline-offset-4 transition-all" href="/templates/creative-studio/contact">Contact</a></li>
      </ul>
    </div>
    <div class="space-y-4">
      <h5 class="font-cs-headline-md text-on-surface text-sm uppercase tracking-widest">Legal &amp; Social</h5>
      <ul class="space-y-2">
        <li><a class="text-on-surface-variant hover:text-secondary hover:underline decoration-secondary decoration-2 underline-offset-4 transition-all" href="/templates/creative-studio/contact">Privacy Policy</a></li>
        <li><a class="text-on-surface-variant hover:text-secondary hover:underline decoration-secondary decoration-2 underline-offset-4 transition-all" href="/templates/creative-studio/contact">Terms of Service</a></li>
        <li><a class="text-on-surface-variant hover:text-secondary hover:underline decoration-secondary decoration-2 underline-offset-4 transition-all" href="/templates/creative-studio/contact">Instagram</a></li>
        <li><a class="text-on-surface-variant hover:text-secondary hover:underline decoration-secondary decoration-2 underline-offset-4 transition-all" href="/templates/creative-studio/contact">Dribbble</a></li>
      </ul>
    </div>
    <div class="space-y-4">
      <h5 class="font-cs-headline-md text-on-surface text-sm uppercase tracking-widest">Newsletter</h5>
      <form class="flex gap-2" id="csNewsletterForm" data-success-target="#csNewsletterSuccess">
        <input class="bg-surface-variant/30 border border-outline-variant/30 rounded-lg px-4 py-2 w-full focus:outline-none focus:ring-2 focus:ring-secondary/50 transition-all" placeholder="Your email" type="email" required />
        <button class="bg-primary text-white p-2 rounded-lg hover:bg-primary-container transition-colors" type="submit">
          <span class="material-symbols-outlined">send</span>
        </button>
      </form>
      <p class="hidden text-on-surface-variant text-sm" id="csNewsletterSuccess">Subscribed! Watch your inbox.</p>
    </div>
  </div>
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mt-16 pt-8 border-t border-outline-variant/10 text-center">
    <p class="font-body-md text-body-md text-on-surface-variant">© 2026 The Creative Collective. Fueling the Creative Spark.</p>
  </div>
</footer>
