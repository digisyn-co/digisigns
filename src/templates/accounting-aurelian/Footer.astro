---
// Canonical footer normalized from the source screens (each shipped a
// slightly different footer layout; this is the consolidated version).
// Newsletter form reuses the shared data-success-target convention.
---

<footer class="bg-primary text-on-primary w-full border-t border-outline-variant/10">
  <div class="max-w-au-container-max mx-auto px-au-margin-mobile md:px-margin-desktop py-au-section-gap flex flex-col md:flex-row justify-between items-start md:items-center gap-12">
    <div class="space-y-6">
      <div class="font-au-headline-md text-au-headline-md text-on-primary italic">Aurelian</div>
      <p class="font-au-body-md text-au-body-md text-on-primary/70 max-w-xs">
        Curating financial legacies for the visionary elite. Precision in craft, since 2008.
      </p>
    </div>
    <div class="grid grid-cols-2 gap-x-16 gap-y-4">
      <a class="font-au-body-md text-au-body-md text-on-primary/70 hover:text-on-primary transition-colors" href="/templates/accounting-aurelian/philosophy">Philosophy</a>
      <a class="font-au-body-md text-au-body-md text-on-primary/70 hover:text-on-primary transition-colors" href="/templates/accounting-aurelian/services">Services</a>
      <a class="font-au-body-md text-au-body-md text-on-primary/70 hover:text-on-primary transition-colors" href="/templates/accounting-aurelian/portfolio">Portfolio</a>
      <a class="font-au-body-md text-au-body-md text-on-primary/70 hover:text-on-primary transition-colors" href="/templates/accounting-aurelian/contact">Contact</a>
    </div>
    <div class="flex flex-col gap-4 w-full md:w-auto md:min-w-[280px]">
      <p class="font-au-label-md text-au-label-md text-on-primary/40 uppercase tracking-wider">Receive the Printed Perspective</p>
      <form id="footerNewsletterForm" data-success-target="#footerNewsletterSuccess" class="flex gap-2">
        <input
          type="email"
          name="email"
          required
          placeholder="Email Address"
          class="w-full bg-transparent border-0 border-b border-white/30 py-2 px-0 text-white placeholder:text-white/40 focus:ring-0 focus:border-tertiary-fixed transition-colors outline-none font-au-body-md"
        />
        <button type="submit" class="shrink-0 text-tertiary-fixed" aria-label="Subscribe">
          <span class="material-symbols-outlined">arrow_right_alt</span>
        </button>
      </form>
      <p id="footerNewsletterSuccess" class="hidden font-au-caption text-au-caption text-tertiary-fixed">Thank you — you're on the list.</p>
    </div>
  </div>
  <div class="max-w-au-container-max mx-auto px-au-margin-mobile md:px-margin-desktop pb-12 flex flex-col md:flex-row justify-between items-center gap-4 border-t border-on-primary/10 pt-8">
    <p class="text-on-primary/50 font-au-caption text-au-caption">© 2026 Aurelian Tax &amp; Advisory. Precision in Craft.</p>
    <div class="flex gap-6">
      <span class="material-symbols-outlined text-on-primary/50">language</span>
      <span class="material-symbols-outlined text-on-primary/50">share</span>
    </div>
  </div>
</footer>
