---
interface Props {
  active: "home" | "philosophy" | "services" | "portfolio" | "insights" | "contact";
}
const { active } = Astro.props;
const links = [
  { href: "/templates/accounting-aurelian/portfolio", label: "Portfolio", key: "portfolio" },
  { href: "/templates/accounting-aurelian/services", label: "Services", key: "services" },
  { href: "/templates/accounting-aurelian/philosophy", label: "Philosophy", key: "philosophy" },
  { href: "/templates/accounting-aurelian/insights", label: "Insights", key: "insights" },
];
---

<header class="bg-surface border-b border-outline-variant/20 sticky top-10 z-50 shadow-sm">
  <nav class="relative flex justify-between items-center w-full px-au-margin-mobile md:px-margin-desktop max-w-au-container-max mx-auto h-24">
    <a href="/templates/accounting-aurelian" class="font-au-headline-md text-au-headline-md text-primary italic tracking-tight">
      Aurelian Tax &amp; Advisory
    </a>
    <div id="mobile-menu-accounting-aurelian" class="hidden lg:flex items-center gap-au-gutter bg-surface border-t border-outline-variant/20 shadow-lg lg:shadow-none lg:border-0">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            "font-au-body-md text-au-body-md transition-colors duration-300",
            active === link.key ? "text-on-tertiary-container font-semibold border-b-2 border-on-tertiary-container pb-1" : "text-on-surface-variant hover:text-primary",
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
    <div class="flex items-center gap-6">
      <a
        href="/templates/accounting-aurelian/contact"
        class:list={[
          "bg-primary text-on-primary px-8 py-3 font-au-label-md text-au-label-md hover:opacity-80 transition-all active:scale-95",
          active === "contact" ? "opacity-80" : "",
        ]}
      >
        Consultation
      </a>
      <button
        type="button"
        class="lg:hidden text-primary p-2"
        aria-label="Toggle menu"
        aria-expanded="false"
        data-mobile-menu-toggle="#mobile-menu-accounting-aurelian"
      >
        <span class="material-symbols-outlined" data-icon-open>menu</span>
        <span class="material-symbols-outlined hidden" data-icon-close>close</span>
      </button>
    </div>
  </nav>
</header>
