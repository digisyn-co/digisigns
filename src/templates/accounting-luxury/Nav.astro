---
// Shared top nav for every Estate & Accord (accounting-luxury) page.
// Source screens used decorative, non-functional labels (Portfolio /
// Advisory / Strategy / Insights) — replaced here with real routes to the
// template's 4 primary pages, matching the required-pages set.
interface Props {
  active: "home" | "about" | "services" | "industries" | "contact";
}
const { active } = Astro.props;

const links = [
  { href: "/templates/accounting-luxury", label: "Home", key: "home" },
  { href: "/templates/accounting-luxury/about", label: "About", key: "about" },
  { href: "/templates/accounting-luxury/services", label: "Services", key: "services" },
  { href: "/templates/accounting-luxury/industries", label: "Industries", key: "industries" },
];
---

<header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-margin-desktop py-4 max-w-container-max mx-auto bg-surface/90 backdrop-blur-md shadow-sm">
  <a href="/templates/accounting-luxury" class="font-headline-sm text-headline-sm tracking-tighter text-primary">ESTATE &amp; ACCORD</a>
  <nav class="hidden md:flex items-center gap-10">
    {links.map((link) => (
      <a
        href={link.href}
        class:list={[
          "font-label-md text-label-md uppercase tracking-widest transition-colors duration-300",
          active === link.key
            ? "text-secondary border-b border-secondary"
            : "text-on-surface hover:text-secondary",
        ]}
      >
        {link.label}
      </a>
    ))}
  </nav>
  <a
    href="/templates/accounting-luxury/contact"
    class:list={[
      "bg-primary text-on-primary px-8 py-3 font-label-md text-label-md uppercase tracking-widest hover:bg-secondary transition-all duration-500 ease-in-out",
      active === "contact" ? "bg-secondary" : "",
    ]}
  >
    Consultation
  </a>
</header>
