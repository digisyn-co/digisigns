---
interface Props {
  active: "home" | "about" | "services" | "industries" | "blog" | "contact";
}
const { active } = Astro.props;
const links = [
  { href: "/templates/accounting-precision", label: "Home", key: "home" },
  { href: "/templates/accounting-precision/services", label: "Services", key: "services" },
  { href: "/templates/accounting-precision/industries", label: "Industries", key: "industries" },
  { href: "/templates/accounting-precision/about", label: "About Us", key: "about" },
  { href: "/templates/accounting-precision/blog", label: "Insights", key: "blog" },
];
---

<header class="bg-surface border-b border-outline-variant/30 sticky top-10 z-50 shadow-sm">
  <nav class="relative flex justify-between items-center w-full px-margin-mobile md:px-margin-desktop max-w-tp-container-max mx-auto h-20">
    <a href="/templates/accounting-precision" class="font-tp-headline-md text-tp-headline-md text-primary">TaxPro &amp; Partners</a>
    <div id="mobile-menu-accounting-precision" class="hidden lg:flex items-center gap-8 bg-surface border-t border-outline-variant/30 shadow-lg lg:shadow-none lg:border-0">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            "font-tp-label-md text-tp-label-md transition-colors duration-200",
            active === link.key ? "text-secondary font-bold border-b-2 border-secondary pb-1" : "text-on-surface-variant hover:text-secondary",
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
    <div class="flex items-center gap-3">
      <a
        href="/templates/accounting-precision/contact"
        class:list={[
          "bg-primary text-on-primary px-6 py-2.5 rounded-lg font-tp-label-md text-tp-label-md hover:opacity-90 active:scale-95 transition-all",
          active === "contact" ? "opacity-90" : "",
        ]}
      >
        Get Started
      </a>
      <button
        type="button"
        class="lg:hidden text-primary p-2"
        aria-label="Toggle menu"
        aria-expanded="false"
        data-mobile-menu-toggle="#mobile-menu-accounting-precision"
      >
        <span class="material-symbols-outlined" data-icon-open>menu</span>
        <span class="material-symbols-outlined hidden" data-icon-close>close</span>
      </button>
    </div>
  </nav>
</header>
