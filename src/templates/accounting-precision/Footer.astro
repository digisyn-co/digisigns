---
// Canonical footer normalized from the source screens (Home, Services,
// Industries, About, Contact all shipped a slightly different footer;
// this is the consolidated version). Newsletter signup wired via the
// shared data-success-target contact-form convention in BaseLayout.
---

<footer class="bg-primary text-on-primary pt-stack-lg pb-stack-md">
  <div class="grid grid-cols-1 md:grid-cols-4 gap-gutter px-margin-mobile md:px-margin-desktop py-stack-md max-w-tp-container-max mx-auto">
    <div class="md:col-span-1">
      <span class="font-tp-headline-md text-tp-headline-md text-on-primary mb-4 block">TaxPro &amp; Partners</span>
      <p class="text-surface-variant/80 font-tp-body-md text-tp-body-md">
        Empowering businesses with precision tax and corporate strategy solutions since 1998.
      </p>
    </div>
    <div>
      <h4 class="font-tp-label-md text-tp-label-md text-secondary-fixed mb-4 uppercase tracking-wider">Services</h4>
      <ul class="space-y-2">
        <li><a class="text-surface-variant/80 hover:text-white underline transition-all font-tp-label-sm text-tp-label-sm" href="/templates/accounting-precision/services">Tax Planning</a></li>
        <li><a class="text-surface-variant/80 hover:text-white underline transition-all font-tp-label-sm text-tp-label-sm" href="/templates/accounting-precision/services">Audit &amp; Assurance</a></li>
        <li><a class="text-surface-variant/80 hover:text-white underline transition-all font-tp-label-sm text-tp-label-sm" href="/templates/accounting-precision/services">Business Advisory</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-tp-label-md text-tp-label-md text-secondary-fixed mb-4 uppercase tracking-wider">Company</h4>
      <ul class="space-y-2">
        <li><a class="text-surface-variant/80 hover:text-white underline transition-all font-tp-label-sm text-tp-label-sm" href="/templates/accounting-precision/about">About Us</a></li>
        <li><a class="text-surface-variant/80 hover:text-white underline transition-all font-tp-label-sm text-tp-label-sm" href="/templates/accounting-precision/industries">Industries</a></li>
        <li><a class="text-surface-variant/80 hover:text-white underline transition-all font-tp-label-sm text-tp-label-sm" href="/templates/accounting-precision/blog">Insights</a></li>
        <li><a class="text-surface-variant/80 hover:text-white underline transition-all font-tp-label-sm text-tp-label-sm" href="/templates/accounting-precision/contact">Contact Us</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-tp-label-md text-tp-label-md text-secondary-fixed mb-4 uppercase tracking-wider">Newsletter</h4>
      <p class="font-tp-label-sm text-tp-label-sm text-surface-variant/80 mb-4">Get corporate tax insights monthly.</p>
      <form id="footerNewsletterForm" data-success-target="#footerNewsletterSuccess" class="flex gap-2">
        <input
          type="email"
          name="email"
          required
          placeholder="Email"
          class="bg-white/10 border border-white/20 rounded-lg px-3 py-2 text-white placeholder:text-white/40 text-sm w-full focus:ring-2 focus:ring-secondary focus:border-secondary outline-none"
        />
        <button type="submit" class="bg-secondary p-2.5 rounded-lg text-white shrink-0" aria-label="Subscribe">
          <span class="material-symbols-outlined">send</span>
        </button>
      </form>
      <p id="footerNewsletterSuccess" class="hidden font-tp-label-sm text-tp-label-sm text-secondary-fixed mt-2">Thanks — you're subscribed.</p>
    </div>
  </div>
  <div class="max-w-tp-container-max mx-auto px-margin-mobile md:px-margin-desktop pt-6 border-t border-white/10 mt-8">
    <p class="text-surface-variant/80 font-tp-label-sm text-tp-label-sm text-center md:text-left">© 2026 TaxPro &amp; Partners. All rights reserved.</p>
  </div>
</footer>
