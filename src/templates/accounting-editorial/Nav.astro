---
interface Props {
  active: "home" | "about" | "services" | "knowledge-hub" | "blog" | "contact";
}
const { active } = Astro.props;
const links = [
  { href: "/templates/accounting-editorial/knowledge-hub", label: "Knowledge Hub", key: "knowledge-hub" },
  { href: "/templates/accounting-editorial/about", label: "About", key: "about" },
  { href: "/templates/accounting-editorial/services", label: "Services", key: "services" },
];
---

<header class="bg-surface border-b border-outline-variant w-full top-10 z-50 sticky">
  <nav class="relative flex justify-between items-center w-full px-margin-mobile md:px-margin-desktop py-4 max-w-si-container-max mx-auto">
    <a href="/templates/accounting-editorial" class="font-si-headline-md text-si-headline-md font-bold text-primary">Strategic Insight</a>
    <div id="mobile-menu-accounting-editorial" class="hidden lg:flex gap-8 items-center bg-surface border-t border-outline-variant">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            "font-si-label-lg text-si-label-lg transition-colors",
            active === link.key ? "text-secondary border-b-2 border-secondary font-bold" : "text-on-surface-variant hover:text-primary",
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
    <div class="flex items-center gap-3">
      <a
        href="/templates/accounting-editorial/contact"
        class:list={[
          "bg-secondary text-on-primary px-6 py-2 font-si-label-lg text-si-label-lg font-bold hover:brightness-110 transition-all uppercase tracking-widest",
          active === "contact" ? "brightness-110" : "",
        ]}
      >
        Contact
      </a>
      <button
        type="button"
        class="lg:hidden text-primary p-2"
        aria-label="Toggle menu"
        aria-expanded="false"
        data-mobile-menu-toggle="#mobile-menu-accounting-editorial"
      >
        <span class="material-symbols-outlined" data-icon-open>menu</span>
        <span class="material-symbols-outlined hidden" data-icon-close>close</span>
      </button>
    </div>
  </nav>
</header>
