---
// Canonical footer normalized from Home, with the real company/agency
// references from the source screen (Moore North America, Doeren
// Mayhew, Pennebaker) genericized to this template's own brand name.
// "Industries" and "Careers" links have no dedicated page in this
// 6-page build and route to Contact/Knowledge Hub instead.
---

<footer class="bg-primary text-on-primary py-section-padding px-margin-desktop">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-gutter mb-20">
      <div class="col-span-1 md:col-span-1">
        <div class="flex flex-col gap-6">
          <div class="font-si-headline-sm text-si-headline-sm font-bold text-on-primary uppercase tracking-tighter">Strategic Insight</div>
          <p class="font-si-label-lg text-si-label-lg opacity-80 leading-relaxed max-w-xs">
            Strategic Insight Advisory is an independent strategic advisory and financial services firm serving decision-makers who expect modern, data-driven execution.
          </p>
          <div class="flex gap-4">
            <a href="/templates/accounting-editorial/contact" class="material-symbols-outlined text-2xl hover:text-secondary-fixed transition-colors cursor-pointer" data-icon="public">public</a>
            <a href="mailto:hello@strategicinsight.example" class="material-symbols-outlined text-2xl hover:text-secondary-fixed transition-colors cursor-pointer" data-icon="alternate_email">alternate_email</a>
            <a href="/templates/accounting-editorial/contact" class="material-symbols-outlined text-2xl hover:text-secondary-fixed transition-colors cursor-pointer" data-icon="groups">groups</a>
          </div>
        </div>
      </div>
      <div class="md:col-span-3">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-gutter mb-12">
          <div>
            <h5 class="font-si-label-lg text-si-label-lg font-bold mb-6 text-secondary-fixed uppercase">Contact</h5>
            <ul class="flex flex-col gap-3 font-si-label-lg text-si-label-lg">
              <li>(888) 870.9873</li>
              <li><a class="hover:text-secondary-fixed cursor-pointer transition-colors" href="/templates/accounting-editorial/contact">Find an Office</a></li>
              <li><a class="hover:text-secondary-fixed cursor-pointer transition-colors" href="mailto:hello@strategicinsight.example">Email Us</a></li>
            </ul>
          </div>
          <div>
            <h5 class="font-si-label-lg text-si-label-lg font-bold mb-6 text-secondary-fixed uppercase">Explore</h5>
            <ul class="flex flex-col gap-3 font-si-label-lg text-si-label-lg">
              <li><a class="hover:text-secondary-fixed cursor-pointer transition-colors" href="/templates/accounting-editorial/knowledge-hub">Knowledge Hub</a></li>
              <li><a class="hover:text-secondary-fixed cursor-pointer transition-colors" href="/templates/accounting-editorial/services">Services</a></li>
              <li><a class="hover:text-secondary-fixed cursor-pointer transition-colors" href="/templates/accounting-editorial/services/tax-strategy">Tax Strategy</a></li>
            </ul>
          </div>
          <div>
            <h5 class="font-si-label-lg text-si-label-lg font-bold mb-6 text-secondary-fixed uppercase">Company</h5>
            <ul class="flex flex-col gap-3 font-si-label-lg text-si-label-lg">
              <li><a class="hover:text-secondary-fixed cursor-pointer transition-colors" href="/templates/accounting-editorial/about">About Us</a></li>
              <li><a class="hover:text-secondary-fixed cursor-pointer transition-colors" href="/templates/accounting-editorial/contact">Careers</a></li>
              <li><a class="hover:text-secondary-fixed cursor-pointer transition-colors" href="/templates/accounting-editorial/contact">Client Portals</a></li>
            </ul>
          </div>
          <div>
            <h5 class="font-si-label-lg text-si-label-lg font-bold mb-6 text-secondary-fixed uppercase">Resources</h5>
            <ul class="flex flex-col gap-3 font-si-label-lg text-si-label-lg">
              <li><a class="hover:text-secondary-fixed cursor-pointer transition-colors" href="/templates/accounting-editorial/contact">Privacy Policy</a></li>
              <li><a class="hover:text-secondary-fixed cursor-pointer transition-colors" href="/templates/accounting-editorial/contact">Terms of Service</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
    <div class="border-t border-on-primary/10 pt-10 flex flex-col md:flex-row justify-between items-center gap-6">
      <p class="font-si-label-lg text-si-label-lg opacity-60">© 2026 Strategic Insight Advisory. All Rights Reserved.</p>
      <div class="flex gap-8 font-si-label-lg text-si-label-lg">
        <a class="opacity-60 hover:opacity-100 transition-opacity" href="/templates/accounting-editorial/contact">Accessibility</a>
      </div>
    </div>
  </div>
</footer>
